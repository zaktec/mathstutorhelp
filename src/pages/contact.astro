---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features from '~/components/widgets/Features.astro';
import { bookingLinks, contactDetails } from '~/utils/siteDetails';

const metadata = {
  title: 'Contact MathsTutorHelp | Manchester Maths Tutor',
  description:
    'Contact MathsTutorHelp in Manchester by phone, WhatsApp or online form for GCSE, IGCSE, Functional Skills, A-Level and group maths tuition.',
};

const haiBlInterestFormUrl = bookingLinks.groupClassInterest;
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Contact MathsTutorHelp"
    title="Contact MathsTutorHelp"
    subtitle="Ask about one-to-one, online or GCSE group tuition. Call, WhatsApp or use the enquiry form below."
    callToAction={{
      variant: 'primary',
      text: `Call ${contactDetails.phoneDisplay}`,
      href: contactDetails.phoneHref,
      icon: 'tabler:phone',
    }}
    callToAction2={{
      text: 'Send a WhatsApp',
      href: contactDetails.whatsappHref,
      icon: 'tabler:brand-whatsapp',
    }}
  />

  <section id="form" class="bg-white py-12 dark:bg-slate-900">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Enquiry Form</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white md:text-4xl">
          Send an Enquiry
        </h2>
        <p class="mt-4 text-lg leading-8 text-muted dark:text-slate-300">
          Use the secure Hai-BL form to tell me what support you need.
        </p>
      </div>

      <div
        class="mx-auto mt-8 max-w-2xl rounded-lg border border-gray-200 bg-brand-soft p-6 text-center shadow-sm dark:border-gray-700 dark:bg-slate-800"
      >
        <h3 class="text-2xl font-bold text-gray-950 dark:text-white">Secure Enquiry Form</h3>
        <p class="mt-3 text-base leading-7 text-muted dark:text-slate-300">
          The form opens on Hai-BL in a new secure page.
        </p>
        <a class="btn-primary mt-5" href={haiBlInterestFormUrl}> Open Hai-BL Form </a>
      </div>
    </div>
  </section>

  <Features
    title="What to Include in Your Message"
    subtitle="These details help me recommend the right tuition option."
    columns={3}
    items={[
      {
        title: 'Student details',
        description: 'Include the year group, current level and exam board if known.',
        icon: 'tabler:school',
      },
      {
        title: 'Goals and topics',
        description: 'Mention target grades and any topics or skills that need support.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'Lesson preference',
        description: 'Choose online, in-person, one-to-one or group tuition.',
        icon: 'tabler:users',
      },
    ]}
  />
</Layout>
