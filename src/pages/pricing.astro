---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Maths Tuition Prices',
  description:
    'Clear Maths Tutor Help pricing for online maths tuition, in-person tuition and group classes in Manchester.',
};

const consultationBookingUrl = 'https://calendar.app.google/VJ6tgEKfsUZAncDe9';
---

<Layout metadata={metadata}>
  <Hero
    tagline="Prices"
    title="Maths Tuition Prices"
    subtitle="Simple, clear pricing for online tuition, in-person tuition and group sessions in Manchester."
    actions={[
      {
        variant: 'primary',
        text: 'Book a Free Consultation',
        href: consultationBookingUrl,
        icon: 'tabler:calendar-check',
      },
      { text: 'View Group Classes', href: '/gcse-revision-class-higher-manchester/' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1635070041078-e363dbe005cb?auto=format&fit=crop&w=1800&q=80',
      alt: 'Maths tuition pricing and study notes',
    }}
  />

  <Features
    title="Tuition Prices"
    subtitle="Choose the lesson format that best fits the student, timetable and learning goals."
    columns={3}
    items={[
      {
        title: 'Online Tutoring',
        description:
          '<strong class="text-3xl text-gray-900 dark:text-white">£25/hr</strong><br />Flexible online maths tuition for GCSE, IGCSE, Functional Skills and A-Level students.',
        icon: 'tabler:device-laptop',
        callToAction: { text: 'Ask about online tuition', href: '/contact/' },
      },
      {
        title: 'In-Person Tutoring',
        description:
          '<strong class="text-3xl text-gray-900 dark:text-white">£30/hr</strong><br />Manchester-based in-person support with clear explanations and personalised practice.',
        icon: 'tabler:user-check',
        callToAction: { text: 'Ask about in-person tuition', href: '/contact/' },
      },
      {
        title: 'Group Session',
        description:
          '<strong class="text-3xl text-gray-900 dark:text-white">£20</strong><br />Small group GCSE Maths classes in Levenshulme, Manchester. Limited places available.',
        icon: 'tabler:users-group',
        callToAction: { text: 'View group classes', href: '/gcse-revision-class-higher-manchester/' },
      },
    ]}
  />

  <Features
    title="What Is Included?"
    subtitle="Lessons focus on understanding, confidence and exam progress."
    columns={3}
    items={[
      {
        title: 'Clear explanations',
        description: 'Topics are broken down step by step so students understand how and when to use each method.',
        icon: 'tabler:list-check',
      },
      {
        title: 'Exam practice',
        description: 'GCSE, IGCSE and A-Level students practise exam-style questions and written working.',
        icon: 'tabler:file-check',
      },
      {
        title: 'Personalised support',
        description: 'Tuition is adapted to the student’s current level, goals and confidence.',
        icon: 'tabler:user',
      },
      {
        title: 'Worksheets and resources',
        description: 'Students receive suitable practice tasks and revision materials where needed.',
        icon: 'tabler:book',
      },
      {
        title: 'Parent updates',
        description: 'Parents can request updates on progress, focus areas and next steps.',
        icon: 'tabler:message-circle',
      },
      {
        title: 'Flexible lesson options',
        description: 'Online, in-person and group class routes are available depending on availability.',
        icon: 'tabler:calendar',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features>

  <FAQs
    title="Pricing FAQs"
    subtitle="Common questions about lesson prices and booking."
    columns={2}
    items={[
      {
        title: 'Is there a free consultation?',
        description:
          'Yes. You can book a free consultation to discuss the student level, goals and best lesson option.',
      },
      {
        title: 'Do group classes cost £20 per session?',
        description:
          'Yes. Group sessions are listed at £20, with some group class pages offering early booking or block booking options.',
      },
      {
        title: 'Can we switch between online and in-person tuition?',
        description: 'Yes, where availability allows. Many families choose the format that fits their timetable.',
      },
      {
        title: 'How do I book?',
        description: 'Use the contact page or the class booking links to request a place or ask about availability.',
      },
    ]}
  />

  <CallToAction
    title="Ready to Choose a Tuition Option?"
    subtitle="Tell us the student level, preferred lesson format and the topics that need support."
    actions={[
      {
        variant: 'primary',
        text: 'Book a Free Consultation',
        href: consultationBookingUrl,
        icon: 'tabler:calendar-check',
      },
      { text: 'View Tuition Services', href: '/maths-tuition/' },
    ]}
  />
</Layout>
