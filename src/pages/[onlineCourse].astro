---
import Layout from '~/layouts/PageLayout.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';
import {
  lessonSteps,
  onlineCourseCards,
  onlinePackages,
  packageFaqs,
  packageIncludes,
  registerInterestUrl,
} from '~/utils/onlineCourses';
import { ctaLabels } from '~/utils/siteDetails';

export function getStaticPaths() {
  return onlineCourseCards.map((course) => ({
    params: { onlineCourse: course.slug },
    props: { course },
  }));
}

const { course } = Astro.props;
const onlineTuitionUrl = getPermalink('/online-tuition');

const metadata = {
  title: course.pageTitle,
  description: course.metaDescription ?? course.intro,
};

const courseLessonSteps = course.lessonSteps ?? lessonSteps;
const courseFaqs = [...course.faqs, ...packageFaqs];
const courseSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: course.pageTitle,
  description: course.metaDescription ?? course.intro,
  provider: {
    '@type': 'EducationalOrganization',
    name: 'MathsTutorHelp',
    sameAs: String(new URL(getPermalink('/'), Astro.site)),
  },
  offers: onlinePackages.map((item) => ({
    '@type': 'Offer',
    name: `${course.title} ${item.title}`,
    category: 'Online maths tuition',
    priceCurrency: 'GBP',
    price: item.price.replace(/[^0-9.]/g, ''),
    availability: 'https://schema.org/InStock',
    url: String(Astro.url),
  })),
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(courseSchema)} />

  <section class="bg-brand-soft py-16 dark:bg-slate-900 md:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Online Courses</p>
        <h1 class="mt-3 text-4xl font-bold tracking-tight text-gray-950 dark:text-white md:text-5xl">
          {course.pageTitle}
        </h1>
        <p class="mt-5 text-lg leading-8 text-muted dark:text-slate-300">
          {course.intro}
        </p>
        {
          course.note && (
            <p class="mt-4 rounded-lg border border-primary/25 bg-white p-4 text-base font-medium leading-7 text-gray-800 dark:border-teal-300/30 dark:bg-slate-800 dark:text-slate-200">
              {course.note}
            </p>
          )
        }
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a class="btn-primary justify-center" href={registerInterestUrl}>{ctaLabels.onlineTuitionInterest}</a>
          <a class="btn-secondary justify-center" href={onlineTuitionUrl}>Back to Online Courses</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-14 dark:bg-slate-900">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 sm:px-6 lg:grid-cols-2">
      <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800">
        <h2 class="text-2xl font-bold text-gray-950 dark:text-white">Who This Course Is For</h2>
        <ul class="mt-5 space-y-3 text-muted dark:text-slate-300">
          {
            course.whoFor.map((item) => (
              <li class="flex gap-3">
                <span class="mt-2 size-2 rounded-full bg-secondary" aria-hidden="true" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </article>

      <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800">
        <h2 class="text-2xl font-bold text-gray-950 dark:text-white">What Students Will Learn</h2>
        <ul class="mt-5 grid gap-3 text-muted dark:text-slate-300 sm:grid-cols-2">
          {
            course.learn.map((item) => (
              <li class="flex gap-3">
                <span class="mt-2 size-2 rounded-full bg-primary" aria-hidden="true" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </article>
    </div>
  </section>

  <section class="bg-brand-soft py-14 dark:bg-slate-900">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Lesson Structure</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white">How Lessons Work</h2>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          courseLessonSteps.map((step) => (
            <div class="rounded-lg border border-gray-200 bg-white p-5 text-base font-semibold leading-7 text-gray-800 shadow-sm dark:border-gray-700 dark:bg-slate-800 dark:text-slate-200">
              {step}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-white py-14 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Packages</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white">
          Then Choose Your Support Level
        </h2>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {
          onlinePackages.map((item) => (
            <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800">
              <h3 class="text-xl font-bold text-gray-950 dark:text-white">{item.title}</h3>
              <p class="mt-3 text-muted dark:text-slate-300">{item.detail}</p>
              <p class="mt-5 text-2xl font-extrabold text-primary">{item.price}</p>
              {item.note && <p class="mt-3 text-sm font-semibold text-secondary dark:text-teal-200">{item.note}</p>}
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-brand-soft py-14 dark:bg-slate-900">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Included</p>
          <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white">
            What Every Support Level Includes
          </h2>
        </div>
        <ul class="grid gap-3 sm:grid-cols-2">
          {
            packageIncludes.map((item) => (
              <li class="rounded-lg border border-gray-200 bg-white p-4 text-base font-medium leading-7 text-gray-800 shadow-sm dark:border-gray-700 dark:bg-slate-800 dark:text-slate-200">
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <FAQs title={`${course.title} FAQs`} columns={2} items={courseFaqs} />

  <CallToAction
    title="Ready to Get Started?"
    subtitle="Register your interest and I will get back to you with the most suitable support option."
    actions={[
      {
        variant: 'primary',
        text: ctaLabels.onlineTuitionInterest,
        href: registerInterestUrl,
        icon: 'tabler:calendar-check',
      },
      {
        text: 'Back to Online Courses',
        href: onlineTuitionUrl,
      },
    ]}
  />
</Layout>
