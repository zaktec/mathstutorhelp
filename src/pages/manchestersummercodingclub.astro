---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getAsset, getPermalink } from '~/utils/permalinks';
import { bookingLinks, ctaLabels } from '~/utils/siteDetails';

const metadata = {
  title: 'Summer Coding Course Manchester | Python Ages 13-17',
  description:
    'Summer Python coding course in Manchester for ages 13-17. Build real apps, boost problem-solving and learn Python with a qualified teacher in a calm small group.',
};

const interestFormUrl = bookingLinks.groupClassInterest;
const contactUrl = getPermalink('/contact');
const onlineTuitionUrl = getPermalink('/online-tuition');
---

<Layout metadata={metadata}>
  <Hero
    tagline="Summer Coding Course"
    title="Python Coding Course in Manchester for Ages 13-17"
    subtitle="Build real apps, boost problem-solving and learn Python from scratch with a qualified teacher. No experience needed."
    actions={[
      {
        variant: 'primary',
        text: ctaLabels.codingCourseInterest,
        href: interestFormUrl,
        target: '_blank',
        icon: 'tabler:code',
      },
      { text: 'Ask a Question', href: contactUrl },
    ]}
    image={{
      src: getAsset('/images/online-maths-lesson-laptop.jpg'),
      alt: 'Student learning online coding on a laptop',
    }}
  />

  <Features
    title="Course Details"
    subtitle="A practical six-week course for beginners who want to learn coding with calm, teacher-led support."
    columns={3}
    items={[
      {
        title: 'Ages 13-17',
        description: 'Suitable for complete beginners and students interested in coding, maths or technology.',
        icon: 'tabler:users',
      },
      {
        title: 'Sundays 11:00am-12:00pm',
        description: 'Six sessions from 26 July to 30 August at Levenshulme High School.',
        icon: 'tabler:clock',
      },
      {
        title: '£100 for 6 sessions',
        description: 'Approximately £17 per session, with no payment required to register interest.',
        icon: 'tabler:coin-pound',
      },
      {
        title: 'Max 7 students',
        description: 'Small-group teaching from a qualified maths teacher and computer science tutor gives students focused support while they build projects.',
        icon: 'tabler:users-group',
      },
      {
        title: 'Laptop required',
        description: 'Students use free Python software, with setup completed before the course starts.',
        icon: 'tabler:device-laptop',
      },
      {
        title: 'Final project',
        description: 'Students build a complete Python program and receive a certificate.',
        icon: 'tabler:award',
      },
    ]}
  />

  <Content
    isReversed
    title="What Students Will Learn"
    items={[
      {
        title: 'Python from scratch',
        description: 'Students learn the basics step by step and build real programs each week.',
      },
      {
        title: 'Apps and mini tools',
        description: 'Projects include quizzes, small apps and practical tools that make coding feel real.',
      },
      {
        title: 'Maths through coding',
        description: 'The course includes formulas, substitution, sequences, averages, percentages and logic.',
      },
      {
        title: 'Next steps',
        description: 'Students can progress to advanced coding, web development or GCSE Computer Science support.',
      },
    ]}
    image={{
      src: getAsset('/images/online-maths-tutoring-packages.jpg'),
      alt: 'Python coding lesson on a laptop',
    }}
  >
    <Fragment slot="content">
      <p>
        Give your child a powerful head start in coding this summer in a calm, focused, small-group environment.
        Students learn step by step, build real programs and practise problem-solving through coding.
      </p>
    </Fragment>
  </Content>

  <Features
    title="Maths Skills Included"
    subtitle="The course links Python coding with useful maths thinking and logical reasoning."
    columns={3}
    items={[
      {
        title: 'Algebra in code',
        description: 'Students practise formulas, substitution and using variables in real Python programs.',
        icon: 'tabler:math-function',
      },
      {
        title: 'Sequences and patterns',
        description: 'Coding tasks help students spot patterns, repeat steps and build logical routines.',
        icon: 'tabler:repeat',
      },
      {
        title: 'Averages and percentages',
        description: 'Projects can include mean, minimum, maximum, percentages and simple calculations.',
        icon: 'tabler:percentage',
      },
      {
        title: 'Logical reasoning',
        description: 'Students practise if statements, loops and step-by-step decision making.',
        icon: 'tabler:bulb',
      },
      {
        title: 'GCSE Maths thinking',
        description: 'Coding supports careful working, accuracy and problem-solving habits.',
        icon: 'tabler:certificate',
      },
      {
        title: 'Real scenarios',
        description: 'Students apply maths ideas inside quizzes, mini tools and simple app-style projects.',
        icon: 'tabler:apps',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-brand-soft dark:bg-transparent"></div>
    </Fragment>
  </Features>

  <Features
    title="Requirements and Final Outcome"
    subtitle="Students finish with a practical project and a clearer route for future coding progress."
    columns={3}
    items={[
      {
        title: 'Laptop required',
        description: 'Students bring a laptop and use free beginner-friendly Python software.',
        icon: 'tabler:device-laptop',
      },
      {
        title: 'No internet needed',
        description: 'Once the software is set up, coding tasks can work offline during lessons.',
        icon: 'tabler:wifi-off',
      },
      {
        title: 'Complete Python project',
        description: 'Students build a complete Python program by the end of the six sessions.',
        icon: 'tabler:code',
      },
      {
        title: 'Certificate included',
        description: 'Students receive a certificate for completing the course.',
        icon: 'tabler:award',
      },
      {
        title: 'Future progression',
        description: 'Students can move on to advanced coding, web development or GCSE Computer Science support.',
        icon: 'tabler:route',
      },
      {
        title: 'Small group support',
        description: 'The group is capped at 7 students so learners can ask questions and get help.',
        icon: 'tabler:users-group',
      },
    ]}
  />

  <FAQs
    title="Coding Course FAQs"
    columns={2}
    items={[
      {
        title: 'Do students need coding experience?',
        description: 'No. Complete beginners are welcome, and the course starts from the basics.',
      },
      {
        title: 'Do students need internet in lessons?',
        description: 'No. The course uses offline Python software once everything is set up.',
      },
      {
        title: 'What software is used?',
        description: 'Students use Thonny, a free Python editor that is suitable for beginners.',
      },
      {
        title: 'Is an online option available?',
        description: `An online version is planned. You can also view current online support here: <a class="underline" href="${onlineTuitionUrl}">Online Tuition</a>.`,
      },
      {
        title: 'Is payment required to register interest?',
        description: 'No. Payment is not required to register interest.',
      },
    ]}
  />

  <CallToAction
    title="Only 7 Spaces Available"
    subtitle="Register interest now for the Manchester summer Python course. No payment is required to register interest."
    actions={[
      {
        variant: 'primary',
        text: ctaLabels.codingCourseInterest,
        href: interestFormUrl,
        target: '_blank',
        icon: 'tabler:send',
      },
      { text: 'Contact Us', href: contactUrl },
    ]}
  />
</Layout>
