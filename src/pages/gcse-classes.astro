---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Image from '~/components/common/Image.astro';
import { getPermalink } from '~/utils/permalinks';
import { bookingLinks, ctaLabels, tuitionPrices } from '~/utils/siteDetails';
import { siteImages } from '~/data/images';

const metadata = {
  title: 'MathsTutorHelp Group Classes Levenshulme',
  description:
    'MathsTutorHelp group classes in Levenshulme, Manchester, including GCSE Foundation, GCSE Higher and beginner coding where available.',
};

const interestFormUrl = bookingLinks.groupClassInterest;
const higherClassUrl = getPermalink('/gcse-revision-class-higher-manchester');
const foundationClassUrl = getPermalink('/gcse-foundation-maths-tutoring-club-2025');
const contactUrl = getPermalink('/contact');
const onlineTuitionUrl = getPermalink('/online-tuition');
const codingCourseUrl = getPermalink('/manchestersummercodingclub');
---

<Layout metadata={metadata}>
  <Hero
    tagline="MathsTutorHelp Group Classes"
    title="Group Classes in Levenshulme"
    subtitle={`Small, teacher-led MathsTutorHelp group classes in Levenshulme, Manchester. Options include GCSE Foundation, GCSE Higher and beginner coding courses when available.`}
    actions={[
      {
        variant: 'primary',
        text: ctaLabels.groupClassInterest,
        href: interestFormUrl,
        target: '_blank',
        icon: 'tabler:calendar-check',
      },
      { text: 'Compare Group Classes', href: '#class-options' },
    ]}
  />

  <section id="class-options" class="scroll-mt-[72px] bg-white py-8 dark:bg-slate-900 md:py-10 lg:py-12">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Levenshulme Classes</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white md:text-4xl">
          Choose the Right Group Class
        </h2>
        <p class="mt-4 text-base leading-7 text-muted dark:text-slate-300">
          Group classes are for students who benefit from a weekly routine, teacher-led explanations and guided exam
          practice. Maths groups are separated by level, and coding is available as a separate beginner group course.
        </p>
      </div>

      <div class="mt-8 grid gap-5 lg:grid-cols-3">
        <article
          class="rounded-lg border border-gray-200 bg-brand-soft p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800"
        >
          <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Grades 6-9</p>
          <h3 class="mt-2 text-2xl font-bold text-gray-950 dark:text-white">GCSE Higher Maths Classes</h3>
          <p class="mt-3 text-base leading-7 text-muted dark:text-slate-300">
            For Higher Tier students who need topic revision, harder exam questions and clearer problem-solving methods.
          </p>
          <a class="btn-secondary mt-5 w-full justify-center sm:w-auto" href={higherClassUrl}>View Higher Class</a>
        </article>

        <article
          class="rounded-lg border border-gray-200 bg-brand-soft p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800"
        >
          <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Grades 4-5</p>
          <h3 class="mt-2 text-2xl font-bold text-gray-950 dark:text-white">GCSE Foundation Maths Tutoring</h3>
          <p class="mt-3 text-base leading-7 text-muted dark:text-slate-300">
            For Foundation Tier students who need stronger core methods, steady practice and confidence with exam-style
            questions.
          </p>
          <a class="btn-secondary mt-5 w-full justify-center sm:w-auto" href={foundationClassUrl}
            >View Foundation Class</a
          >
        </article>

        <article
          class="rounded-lg border border-gray-200 bg-brand-soft p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800"
        >
          <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Beginner coding</p>
          <h3 class="mt-2 text-2xl font-bold text-gray-950 dark:text-white">Coding Group Class</h3>
          <p class="mt-3 text-base leading-7 text-muted dark:text-slate-300">
            For students who want to learn beginner Python, build logic and improve practical problem-solving skills.
          </p>
          <a class="btn-secondary mt-5 w-full justify-center sm:w-auto" href={codingCourseUrl}
            >View Coding Group Class</a
          >
        </article>
      </div>

      <div
        class="mt-6 rounded-lg border border-primary/20 bg-white p-5 text-center shadow-sm dark:border-slate-700 dark:bg-slate-800"
      >
        <p class="text-lg font-bold text-gray-950 dark:text-white">Not sure which class is right?</p>
        <p class="mt-2 text-base leading-7 text-muted dark:text-slate-300">
          Send the student's year group, current grade and target grade, and MathsTutorHelp will suggest the best next
          step.
        </p>
        <a class="btn-secondary mt-4 justify-center" href={contactUrl}>Ask About Classes</a>
      </div>
    </div>
  </section>

  <Features
    title="Why Choose a Group Class?"
    subtitle="A good fit for students who need routine, guided practice and a supportive class environment."
    columns={3}
    items={[
      {
        title: 'Small groups',
        description: 'Classes are capped so students can ask questions and receive individual attention.',
        icon: 'tabler:users-group',
      },
      {
        title: 'Clear weekly structure',
        description: 'Students work through focused topics, guided examples and practice tasks.',
        icon: 'tabler:list-check',
      },
      {
        title: tuitionPrices.smallGroup.display,
        description: 'GCSE Maths group sessions are a lower-cost route for regular support than one-to-one tuition.',
        icon: 'tabler:coin-pound',
      },
    ]}
  />

  <Features
    title="Class Details at a Glance"
    subtitle="The individual class pages include the latest timings, course plans and booking details."
    columns={3}
    items={[
      {
        title: 'Location',
        description: 'Levenshulme High School, Manchester, M19 1FS, unless a class page confirms otherwise.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Limited places',
        description: 'Register your interest early to ask about availability or join the waitlist.',
        icon: 'tabler:calendar-check',
      },
      {
        title: 'Other support available',
        description: `Beginner coding group classes may run in Levenshulme. One-to-one tuition is ${tuitionPrices.oneToOne.display}; online tuition is ${tuitionPrices.online.display}.`,
        icon: 'tabler:code',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-brand-soft dark:bg-transparent"></div>
    </Fragment>
  </Features>

  <FAQs
    title="Group Class FAQs"
    columns={2}
    items={[
      {
        title: 'How much are GCSE group classes?',
        description: `Small group classes are ${tuitionPrices.smallGroup.display}. Some class pages may mention advance block booking options where available.`,
      },
      {
        title: 'Which class should my child choose?',
        description:
          'Foundation is usually for students working towards grades 4-5. Higher is usually for students aiming for grades 6-9.',
      },
      {
        title: 'Are online classes available instead?',
        description: `Students who prefer learning from home can view online tuition here: <a class="underline" href="${onlineTuitionUrl}">Online Maths Tuition</a>.`,
      },
    ]}
  />

  <section class="bg-white py-8 dark:bg-slate-900 md:py-10 lg:py-12">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Class Images</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white">Group Class Flyers</h2>
      </div>
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <Image
          class="mx-auto w-full rounded-lg border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-slate-800"
          src={siteImages.gallery.gcseFlyer}
          alt="MathsTutorHelp GCSE Maths classes flyer for Higher and Foundation students in Manchester"
          width={720}
          height={874}
          widths={[400, 720, 960]}
          sizes="(max-width: 767px) 100vw, 50vw"
          layout="responsive"
          format="webp"
          loading="lazy"
        />
        <Image
          class="mx-auto w-full rounded-lg border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-slate-800"
          src={siteImages.gallery.codingFlyer}
          alt="MathsTutorHelp Manchester Summer Coding Club flyer for students aged 13 to 17"
          width={720}
          height={874}
          widths={[400, 720, 960]}
          sizes="(max-width: 767px) 100vw, 50vw"
          layout="responsive"
          format="webp"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <CallToAction
    title="Interested in Levenshulme Group Classes?"
    subtitle="Register your interest and include the student's year group, current level and the class you are interested in."
    actions={[
      {
        variant: 'primary',
        text: ctaLabels.groupClassInterest,
        href: interestFormUrl,
        target: '_blank',
        icon: 'tabler:calendar-check',
      },
      { text: 'View Coding Group Class', href: codingCourseUrl },
    ]}
  />
</Layout>
