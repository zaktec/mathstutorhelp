---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import CourseGrid from '~/components/widgets/CourseGrid.astro';
import MembershipComparison from '~/components/widgets/MembershipComparison.astro';
import { onlineCourseCards, onlinePackages, registerInterestUrl } from '~/utils/onlineCourses';
import { siteImages } from '~/data/images';
import { bookingLinks } from '~/utils/siteDetails';

const metadata = {
  title: 'Online Maths, Problem-Solving & Python Courses',
  description:
    'Online courses for Year 6, KS3, GCSE, IGCSE, Functional Skills and A-Level Maths, plus Maths Challenge and Python pathways with tutor-monitored progress.',
};

const coreMathsCourseOrder = [
  'gcse-foundation-maths',
  'gcse-higher-maths',
  'ks3-maths',
  'year-6-maths',
  'functional-skills-maths',
  'igcse-maths',
  'a-level-maths',
];
const enrichmentCourseOrder = ['maths-challenge-problem-solving-club', 'coding-problem-solving'];
const getCourses = (courseOrder: string[]) =>
  courseOrder
    .map((slug) => onlineCourseCards.find((course) => course.slug === slug))
    .filter((course): course is (typeof onlineCourseCards)[number] => Boolean(course));
const coreMathsCourses = getCourses(coreMathsCourseOrder);
const enrichmentCourses = getCourses(enrichmentCourseOrder);
---

<Layout metadata={metadata}>
  <Hero
    tagline="MathsTutorHelp Online"
    title="Online Maths, Problem-Solving & Python Courses"
    subtitle="Structured online courses for students who need regular guidance, weekly practice and expert tutor support — without committing to weekly one-to-one lessons."
    content={`<ul class="mx-auto mt-6 grid max-w-2xl gap-2 text-left text-sm font-medium text-gray-800 dark:text-slate-200 sm:text-base"><li>✓ One selected course or pathway level matched to the student</li><li>✓ New lessons released weekly to support steady progress</li><li>✓ Tutor-monitored progress in every package</li><li>✓ Live online tutor support included with Silver and Gold</li></ul>`}
    actions={[
      {
        variant: 'primary',
        text: 'Register Interest',
        href: registerInterestUrl,
      },
      { text: 'Compare Plans', href: '#plans' },
    ]}
    image={{
      src: siteImages.onlinePackages,
      alt: 'Online maths tutoring packages',
    }}
  />

  <section class="bg-brand-soft py-12 dark:bg-slate-900">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">
          Choose the Right Format
        </p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white">
          Live Tuition or an Online Course Membership?
        </h2>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-2">
        <article
          class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800"
        >
          <h3 class="text-xl font-bold text-gray-950 dark:text-white">Live Online Tuition</h3>
          <p class="mt-3 leading-7 text-muted dark:text-slate-300">
            A scheduled one-to-one lesson with Mr Sheraz, adapted in real time to the student’s questions and goals.
          </p>
          <a class="btn-secondary mt-5 justify-center" href={bookingLinks.freeConsultation}>Book a Free Consultation</a>
        </article>
        <article
          class="rounded-lg border border-primary/30 bg-white p-6 shadow-sm dark:border-teal-300 dark:bg-slate-800"
        >
          <h3 class="text-xl font-bold text-gray-950 dark:text-white">Online Course Memberships</h3>
          <p class="mt-3 leading-7 text-muted dark:text-slate-300">
            A selected platform course released week by week, with tutor monitoring. Silver and Gold also include a
            fixed number of live online lessons each month.
          </p>
          <a class="btn-primary mt-5 justify-center" href="#plans">Compare Plans</a>
        </article>
      </div>
    </div>
  </section>

  <Features
    tagline="Three Simple Steps"
    title="How online support works"
    subtitle="One selected course or pathway level. Weekly lesson release. Tutor-monitored progress. Flexible monthly learning."
    columns={3}
    items={[
      {
        title: '1. Choose a course',
        description: 'Select the right maths course, Maths Challenge level or Python pathway level for the student.',
        icon: 'tabler:books',
      },
      {
        title: '2. Learn week by week',
        description:
          'Lessons, worksheets and practice tasks are released gradually so students build confidence step by step.',
        icon: 'tabler:list-check',
      },
      {
        title: '3. Get the right support',
        description: 'Every package includes tutor progress monitoring; Silver and Gold also include live lessons.',
        icon: 'tabler:video',
      },
    ]}
  />

  <section class="bg-brand-soft py-12 dark:bg-slate-900">
    <div class="mx-auto grid max-w-6xl gap-5 px-4 sm:px-6 md:grid-cols-2">
      <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Stay Focused</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950 dark:text-white">Course access</h2>
        <p class="mt-3 leading-7 text-muted dark:text-slate-300">
          Each membership includes access to <strong>one selected course or pathway level</strong>. Students do not get
          unlimited access to every course, keeping the work focused and matched to their level.
        </p>
        <p class="mt-3 font-semibold leading-7 text-gray-800 dark:text-slate-200">
          Extra course access can be added if needed for a small additional monthly fee.
        </p>
      </article>
      <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Steady Progress</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950 dark:text-white">Weekly lesson release</h2>
        <p class="mt-3 leading-7 text-muted dark:text-slate-300">
          Course content is released gradually to encourage regular practice and better understanding.
          <strong>Bronze, Silver and Gold include weekly lesson release, not instant full-course access.</strong>
        </p>
      </article>
    </div>
  </section>

  <section class="bg-white py-14 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Online Courses</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white md:text-4xl">
          Choose Your Course
        </h2>
        <p class="mt-4 text-lg leading-8 text-muted dark:text-slate-300">
          Start with the student’s subject and level, then choose how much monthly tutor support they need.
        </p>
      </div>

      <div class="mt-10 space-y-12">
        <CourseGrid title="Core Maths Courses" courses={coreMathsCourses} />
        <CourseGrid
          title="Challenge & Enrichment Courses"
          courses={enrichmentCourses}
          featuredSlugs={['maths-challenge-problem-solving-club']}
        />
      </div>
    </div>
  </section>

  <MembershipComparison packages={onlinePackages} enquiryUrl={registerInterestUrl} />

  <section class="bg-white py-12 dark:bg-slate-900">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <div
        class="rounded-lg border border-gray-200 bg-gray-50 p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800 sm:p-8"
      >
        <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
          <div>
            <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Optional Extra</p>
            <h2 class="mt-2 text-2xl font-bold text-gray-950 dark:text-white">Want instant full-course access?</h2>
            <p class="mt-3 leading-7 text-muted dark:text-slate-300">
              For families who prefer self-paced learning, access to one selected course or pathway level can be
              purchased separately.
            </p>
            <h3 class="mt-5 text-lg font-bold text-gray-950 dark:text-white">Full Course Access includes:</h3>
            <ul class="mt-3 grid gap-2 text-sm leading-6 text-muted dark:text-slate-300 sm:grid-cols-2">
              <li>✓ One selected course or pathway level unlocked immediately</li>
              <li>✓ Self-paced learning</li>
              <li>✓ Worksheets and practice tasks</li>
              <li>✓ No live lesson included</li>
              <li>✓ No monthly subscription required</li>
            </ul>
          </div>
          <div class="md:min-w-56 md:text-center">
            <p class="text-3xl font-extrabold text-primary">£99 one-off</p>
            <a class="btn-secondary mt-4 w-full justify-center" href={registerInterestUrl}
              >Ask About Full Course Access</a
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <Features
    tagline="Trusted Support"
    title="Why parents choose MathsTutorHelp"
    columns={3}
    items={[
      {
        title: 'Experienced tutor',
        description: 'Taught by an experienced Maths and Computing tutor.',
        icon: 'tabler:award',
      },
      {
        title: 'Wide curriculum support',
        description: 'Maths from Year 6 to A-Level, plus Maths Challenge and Python pathways.',
        icon: 'tabler:books',
      },
      {
        title: 'Clear learning structure',
        description: 'Weekly structure to avoid rushed learning.',
        icon: 'tabler:list-details',
      },
      {
        title: 'Flexible each month',
        description: 'Choose course access or add live lessons when needed.',
        icon: 'tabler:calendar',
      },
      {
        title: 'Online tutor access',
        description: 'Live online lessons are included in Silver and Gold.',
        icon: 'tabler:device-laptop',
      },
      {
        title: 'Parent-friendly guidance',
        description: 'The tutor reviews completed work and gives clear guidance on the next steps.',
        icon: 'tabler:users',
      },
    ]}
  >
    <Fragment slot="bg"><div class="absolute inset-0 bg-white dark:bg-slate-900"></div></Fragment>
  </Features>

  <FAQs
    title="Online Tuition FAQs"
    columns={2}
    items={[
      {
        title: 'Do students get access to every course?',
        description:
          'No. Each membership includes one selected course or one level from a multi-level pathway. Extra access can be added if needed.',
      },
      {
        title: 'Why are lessons released weekly?',
        description:
          'Weekly release helps students build understanding gradually and avoids rushing through the course without enough practice.',
      },
      {
        title: 'How does the tutor monitor progress?',
        description:
          'The tutor reviews completed lessons and practice work, checks understanding and uses this information to guide the student’s next steps.',
      },
      {
        title: 'Is Bronze enough?',
        description:
          'Bronze is best for independent learners who mainly need structure, worksheets and light support. Students who need live tutor help should choose Silver or Gold.',
      },
      {
        title: 'Is Silver or Gold better for GCSE?',
        description:
          'Silver is suitable for light monthly guidance. Gold is better for students who need more regular GCSE exam preparation and personalised support.',
      },
      {
        title: 'Is WhatsApp support unlimited?',
        description:
          'No. WhatsApp support is for short course questions and guidance. It is not a replacement for live tutoring.',
      },
      {
        title: 'Can my child book extra lessons?',
        description: 'Yes. Extra one-to-one lessons can be booked separately if more support is needed.',
      },
      {
        title: 'Can I cancel?',
        description: 'Yes. There is no long-term contract, and you can cancel anytime.',
      },
    ]}
  />

  <CallToAction
    title="Not Sure Which Package to Choose?"
    subtitle="Tell me what support your child needs and I will help you choose the right monthly option."
    actions={[
      {
        variant: 'primary',
        text: 'Ask About Online Tuition',
        href: registerInterestUrl,
        icon: 'tabler:calendar-check',
      },
    ]}
  />
</Layout>
