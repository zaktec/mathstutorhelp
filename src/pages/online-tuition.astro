---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';
import { onlineCourseCards, onlinePackages, overviewPackageIncludes, registerInterestUrl } from '~/utils/onlineCourses';

const metadata = {
  title: 'Online Maths Tuition',
  description:
    'Online maths tuition for Year 6, KS3, GCSE, IGCSE, Functional Skills and A-Level students, with clear one-to-one support and flexible packages.',
};

const contactUrl = getPermalink('/contact');
const groupClassesUrl = getPermalink('/online-group-classes');
---

<Layout metadata={metadata}>
  <Hero
    tagline="Online Maths Tuition"
    title="Online Maths Tuition Packages"
    subtitle="Flexible one-to-one online maths tuition for students who need clear teaching, regular practice and calm support from home."
    actions={[
      { variant: 'primary', text: 'Register Interest', href: registerInterestUrl, icon: 'tabler:calendar-check' },
      { text: 'Contact Us', href: contactUrl },
    ]}
    image={{
      src: 'https://i0.wp.com/mathstutorhelp.com/wp-content/uploads/2024/06/onlinemathstutorings-scaled.jpg?fit=1800%2C1200&ssl=1',
      alt: 'Online maths tutoring packages',
    }}
  />

  <section class="bg-white py-14 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Online Maths Tutoring</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white md:text-4xl">
          Choose the Right Online Support
        </h2>
        <p class="mt-4 text-lg leading-8 text-muted dark:text-slate-300">
          Online support is available for students at different stages, from Year 6 preparation to GCSE, IGCSE,
          Functional Skills, A-Level and beginner coding. Choose a course below to view more details, topics covered
          and enrolment options.
        </p>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {
          onlineCourseCards.map((course) => (
            <article class="flex h-full flex-col rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800">
              <h3 class="text-xl font-bold text-gray-950 dark:text-white">{course.title}</h3>
              <p class="mt-3 text-sm leading-6 text-muted dark:text-slate-300">{course.description}</p>
              <ul class="mt-4 space-y-2 text-sm leading-6 text-muted dark:text-slate-300">
                {course.bullets.map((item) => (
                  <li class="flex gap-2">
                    <span class="mt-2 size-1.5 rounded-full bg-secondary" aria-hidden="true" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-auto pt-5">
                <a class="btn-secondary w-full justify-center sm:w-auto" href={getPermalink(`/${course.slug}`)}>
                  {course.buttonText}
                </a>
              </div>
            </article>
          ))
        }
      </div>

    </div>
  </section>

  <section class="bg-brand-soft py-14 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">1:1 Online Tutoring</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white md:text-4xl">
          Choose the Package That Suits Your Child
        </h2>
        <p class="mt-4 text-lg leading-8 text-muted dark:text-slate-300">
          Each booking is a 55-minute live online session with focused teaching, guided practice and clear next steps.
        </p>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {
          onlinePackages.map((item) => (
            <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800">
              <h3 class="text-xl font-bold text-gray-950 dark:text-white">{item.title} Package</h3>
              <p class="mt-3 text-muted dark:text-slate-300">{item.detail}</p>
              <p class="mt-6 text-3xl font-extrabold text-primary">{item.price}</p>
              {item.note && <p class="mt-3 text-sm font-semibold text-secondary dark:text-teal-200">{item.note}</p>}
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-white py-14 dark:bg-slate-900">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Included</p>
          <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white">
            What Every One-to-One Package Includes
          </h2>
          <p class="mt-4 text-lg leading-8 text-muted dark:text-slate-300">
            Each one-to-one package is designed to give students structured support, regular practice and clear next
            steps after every session.
          </p>
        </div>
        <ul class="grid gap-3 sm:grid-cols-2">
          {
            overviewPackageIncludes.map((item) => (
              <li class="rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm font-medium leading-6 text-gray-800 dark:border-gray-700 dark:bg-slate-800 dark:text-slate-200">
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-brand-soft py-10 dark:bg-slate-900">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800">
        <div class="grid gap-5 md:grid-cols-[1fr_auto] md:items-center">
          <div>
            <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Also Available</p>
            <h2 class="mt-2 text-2xl font-bold text-gray-950 dark:text-white">Online Group Classes</h2>
            <p class="mt-3 text-base leading-7 text-muted dark:text-slate-300">
              Small online group classes may be available for GCSE Maths and beginner coding. These are suitable for
              students who want regular support at a lower cost than one-to-one tuition.
            </p>
            <ul class="mt-4 grid gap-2 text-sm text-muted dark:text-slate-300 sm:grid-cols-2">
              <li>Small groups</li>
              <li>Guided practice</li>
              <li>Topic revision</li>
              <li>Exam-style questions</li>
            </ul>
          </div>
          <a class="btn-secondary justify-center" href={groupClassesUrl}>Ask About Group Classes</a>
        </div>
      </div>
    </div>
  </section>

  <FAQs
    title="Online Tuition FAQs"
    columns={2}
    items={[
      {
        title: 'Which levels can be taught online?',
        description: 'Online tuition is available for Year 6, KS3, GCSE, IGCSE, Functional Skills and A-Level maths.',
      },
      {
        title: 'How long is each lesson?',
        description: 'Each live online booking is a 55-minute session.',
      },
      {
        title: 'Does online tuition include exam practice?',
        description: 'Yes. GCSE, IGCSE and A-Level lessons can include topic revision, past papers and exam-style questions.',
      },
      {
        title: 'What does the student need?',
        description: 'A reliable internet connection, a quiet place to work and a device suitable for video lessons.',
      },
    ]}
  />

  <CallToAction
    title="Ready to Get Started?"
    subtitle="Register your interest and I will get back to you with the best support option for your child."
    actions={[
      {
        variant: 'primary',
        text: 'Register Interest',
        href: registerInterestUrl,
        icon: 'tabler:calendar-check',
      },
    ]}
  />
</Layout>
