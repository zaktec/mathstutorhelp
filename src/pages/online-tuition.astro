---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import CourseGrid from '~/components/widgets/CourseGrid.astro';
import { onlineCourseCards, onlinePackages, registerInterestUrl } from '~/utils/onlineCourses';
import { siteImages } from '~/data/images';

const metadata = {
  title: 'Online Maths Tuition & Course Support',
  description:
    'Flexible online maths support for GCSE, KS3, IGCSE and Functional Skills students. Choose one course, access weekly lessons, worksheets and optional live tutor support.',
};

const courseOrder = [
  'gcse-foundation-maths',
  'gcse-higher-maths',
  'ks3-maths',
  'year-6-maths',
  'functional-skills-maths',
  'igcse-maths',
  'a-level-maths',
  'coding-problem-solving',
];
const orderedCourseCards = courseOrder
  .map((slug) => onlineCourseCards.find((course) => course.slug === slug))
  .filter((course): course is (typeof onlineCourseCards)[number] => Boolean(course));
---

<Layout metadata={metadata}>
  <Hero
    tagline="MathsTutorHelp Online"
    title="Online Maths Tuition & Course Support"
    subtitle="Structured online maths support for students who need regular guidance, weekly practice and expert tutor help — without committing to weekly one-to-one lessons."
    content={`<ul class="mx-auto mt-6 grid max-w-2xl gap-2 text-left text-sm font-medium text-gray-800 dark:text-slate-200 sm:text-base"><li>✓ One selected course matched to your child’s level</li><li>✓ New lessons released weekly to support steady progress</li><li>✓ Optional live online tutor support available</li></ul>`}
    actions={[
      {
        variant: 'primary',
        text: 'Choose Your Online Support Plan',
        href: '#plans',
        icon: 'tabler:arrow-down',
      },
      { text: 'Ask About Online Tuition', href: registerInterestUrl },
    ]}
    image={{
      src: siteImages.onlinePackages,
      alt: 'Online maths tutoring packages',
    }}
  />

  <Features
    tagline="Three Simple Steps"
    title="How online support works"
    subtitle="One selected course. Weekly lesson release. Clear support. Flexible monthly learning."
    columns={3}
    items={[
      {
        title: '1. Choose a course',
        description:
          'Select the course that matches the student’s level, such as GCSE Foundation, GCSE Higher, KS3, IGCSE or Functional Skills.',
        icon: 'tabler:books',
      },
      {
        title: '2. Learn week by week',
        description:
          'Lessons, worksheets and practice tasks are released gradually so students build confidence step by step.',
        icon: 'tabler:list-check',
      },
      {
        title: '3. Get the right support',
        description: 'Choose self-study support, one live lesson or two live lessons per month.',
        icon: 'tabler:video',
      },
    ]}
  />

  <section class="bg-brand-soft py-12 dark:bg-slate-900">
    <div class="mx-auto grid max-w-6xl gap-5 px-4 sm:px-6 md:grid-cols-2">
      <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Stay Focused</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950 dark:text-white">Course access</h2>
        <p class="mt-3 leading-7 text-muted dark:text-slate-300">
          Each membership includes access to <strong>one selected course</strong>. Students do not get unlimited access
          to every course, keeping the work focused and matched to their level.
        </p>
        <p class="mt-3 font-semibold leading-7 text-gray-800 dark:text-slate-200">
          Extra course access can be added if needed for a small additional monthly fee.
        </p>
      </article>
      <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Steady Progress</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950 dark:text-white">Weekly lesson release</h2>
        <p class="mt-3 leading-7 text-muted dark:text-slate-300">
          Course content is released gradually to encourage regular practice and better understanding.
          <strong>Bronze, Silver and Gold include weekly lesson release, not instant full-course access.</strong>
        </p>
      </article>
    </div>
  </section>

  <section class="bg-white py-14 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Online Courses</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white md:text-4xl">
          Choose Your Course
        </h2>
        <p class="mt-4 text-lg leading-8 text-muted dark:text-slate-300">
          Start with the student's level, then choose how much monthly tutor support they need.
        </p>
      </div>

      <CourseGrid
        title="Online Courses"
        courses={orderedCourseCards}
        featuredSlugs={['gcse-foundation-maths', 'gcse-higher-maths']}
      />
    </div>
  </section>

  <section id="plans" class="scroll-mt-24 bg-brand-soft py-14 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Support Levels</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white md:text-4xl">
          Choose Your Monthly Membership
        </h2>
        <p class="mt-4 text-lg leading-8 text-muted dark:text-slate-300">
          All packages are monthly, with no long-term contract. Choose the level of live support that suits your child.
        </p>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {
          onlinePackages.map((item) => (
            <article
              class:list={[
                'flex h-full flex-col rounded-lg border bg-white p-6 shadow-sm dark:bg-slate-800',
                item.title === 'Silver'
                  ? 'border-primary ring-2 ring-primary/15 dark:border-teal-300'
                  : 'border-gray-200 dark:border-gray-700',
              ]}
            >
              {item.title === 'Silver' && (
                <p class="mb-2 text-xs font-bold uppercase tracking-wide text-secondary dark:text-teal-200">
                  Most popular
                </p>
              )}
              <h3 class="text-xl font-bold text-gray-950 dark:text-white">
                {item.title} — {item.subtitle}
              </h3>
              <p class="mt-3 text-muted dark:text-slate-300">{item.detail}</p>
              <p class="mt-6 text-3xl font-extrabold text-primary">{item.price}</p>
              <ul class="mt-5 space-y-3 text-sm leading-6 text-muted dark:text-slate-300">
                {item.features.map((feature) => (
                  <li class="flex gap-2">
                    <span class="font-bold text-secondary dark:text-teal-200" aria-hidden="true">
                      ✓
                    </span>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
              <a class="btn-primary mt-6 w-full justify-center" href={registerInterestUrl}>
                {item.cta}
              </a>
            </article>
          ))
        }
      </div>
      <p class="mx-auto mt-7 max-w-3xl text-center text-sm font-medium leading-6 text-muted dark:text-slate-300">
        <strong>WhatsApp support</strong> is for short maths questions, guidance and checking understanding. It is not unlimited
        live tutoring and does not replace live lessons.
      </p>
    </div>
  </section>

  <section class="bg-white py-12 dark:bg-slate-900">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <div
        class="rounded-lg border border-gray-200 bg-gray-50 p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800 sm:p-8"
      >
        <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
          <div>
            <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Optional Extra</p>
            <h2 class="mt-2 text-2xl font-bold text-gray-950 dark:text-white">Want instant full-course access?</h2>
            <p class="mt-3 leading-7 text-muted dark:text-slate-300">
              For families who prefer self-paced learning, full-course access can be purchased separately.
            </p>
            <h3 class="mt-5 text-lg font-bold text-gray-950 dark:text-white">Full Course Access includes:</h3>
            <ul class="mt-3 grid gap-2 text-sm leading-6 text-muted dark:text-slate-300 sm:grid-cols-2">
              <li>✓ One selected course unlocked immediately</li>
              <li>✓ Self-paced learning</li>
              <li>✓ Worksheets and practice tasks</li>
              <li>✓ No live lesson included</li>
              <li>✓ No monthly subscription required</li>
            </ul>
          </div>
          <div class="md:min-w-56 md:text-center">
            <p class="text-3xl font-extrabold text-primary">£99 one-off</p>
            <a class="btn-secondary mt-4 w-full justify-center" href={registerInterestUrl}
              >Ask About Full Course Access</a
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <Features
    tagline="Trusted Support"
    title="Why parents choose MathsTutorHelp"
    columns={3}
    items={[
      {
        title: 'Experienced tutor',
        description: 'Taught by an experienced Maths and Computing tutor.',
        icon: 'tabler:award',
      },
      {
        title: 'Wide curriculum support',
        description: 'Support for GCSE, KS3, IGCSE and Functional Skills.',
        icon: 'tabler:books',
      },
      {
        title: 'Clear learning structure',
        description: 'Weekly structure to avoid rushed learning.',
        icon: 'tabler:list-details',
      },
      {
        title: 'Flexible each month',
        description: 'Choose course access or add live lessons when needed.',
        icon: 'tabler:calendar',
      },
      {
        title: 'Online tutor access',
        description: 'Live online lessons are included in Silver and Gold.',
        icon: 'tabler:device-laptop',
      },
      {
        title: 'Parent-friendly guidance',
        description: 'Clear progress guidance without unnecessary jargon.',
        icon: 'tabler:users',
      },
    ]}
  >
    <Fragment slot="bg"><div class="absolute inset-0 bg-white dark:bg-slate-900"></div></Fragment>
  </Features>

  <FAQs
    title="Online Tuition FAQs"
    columns={2}
    items={[
      {
        title: 'Do students get access to every course?',
        description:
          'No. Each membership includes access to one selected course. Extra course access can be added if needed.',
      },
      {
        title: 'Why are lessons released weekly?',
        description:
          'Weekly release helps students build understanding gradually and avoids rushing through the course without enough practice.',
      },
      {
        title: 'Is Bronze enough?',
        description:
          'Bronze is best for independent learners who mainly need structure, worksheets and light support. Students who need live tutor help should choose Silver or Gold.',
      },
      {
        title: 'Is Silver or Gold better for GCSE?',
        description:
          'Silver is suitable for light monthly guidance. Gold is better for students who need more regular GCSE exam preparation and personalised support.',
      },
      {
        title: 'Is WhatsApp support unlimited?',
        description:
          'No. WhatsApp support is for short questions and guidance. It is not a replacement for live tutoring.',
      },
      {
        title: 'Can my child book extra lessons?',
        description: 'Yes. Extra one-to-one lessons can be booked separately if more support is needed.',
      },
      {
        title: 'Can I cancel?',
        description: 'Yes. There is no long-term contract, and you can cancel anytime.',
      },
    ]}
  />

  <CallToAction
    title="Not Sure Which Package to Choose?"
    subtitle="Tell me what support your child needs and I will help you choose the right monthly option."
    actions={[
      {
        variant: 'primary',
        text: 'Ask About Online Tuition',
        href: registerInterestUrl,
        icon: 'tabler:calendar-check',
      },
    ]}
  />
</Layout>
