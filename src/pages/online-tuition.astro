---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';
import {
  onlineCourseCards,
  onlinePackages,
  overviewPackageIncludes,
  packageFaqs,
  registerInterestUrl,
} from '~/utils/onlineCourses';
import { ctaLabels } from '~/utils/siteDetails';
import { siteImages } from '~/data/images';

const metadata = {
  title: 'MathsTutorHelp Online Maths Tuition UK',
  description:
    'MathsTutorHelp online maths tuition and courses for Year 6, KS3, GCSE, IGCSE, Functional Skills, A-Level and beginner Python students across the UK.',
};

const contactUrl = getPermalink('/contact');
const groupClassesUrl = getPermalink('/online-group-classes');
const mathsCourseCards = onlineCourseCards.filter((course) => !course.slug.startsWith('coding-'));
const codingCourseCards = onlineCourseCards.filter((course) => course.slug.startsWith('coding-'));

const courseCardClass =
  'flex h-full flex-col rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800';
---

<Layout metadata={metadata}>
  <Hero
    tagline="MathsTutorHelp Online"
    title="MathsTutorHelp Online Maths and Coding Courses"
    subtitle="Flexible online maths and coding courses from MathsTutorHelp for students who need clear teaching, regular practice and calm support from home."
    actions={[
      {
        variant: 'primary',
        text: ctaLabels.onlineTuitionInterest,
        href: registerInterestUrl,
        icon: 'tabler:calendar-check',
      },
      { text: 'Contact MathsTutorHelp', href: contactUrl },
    ]}
    image={{
      src: siteImages.onlinePackages,
      alt: 'Online maths tutoring packages',
    }}
  />

  <section class="bg-white py-14 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Online Courses</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white md:text-4xl">
          Choose Your Course
        </h2>
        <p class="mt-4 text-lg leading-8 text-muted dark:text-slate-300">
          Browse the courses below to find the right fit for the learner's level. Once you've chosen a course, pick the
          Bronze, Silver or Gold support level that suits your budget and how much live support you'd like.
        </p>
      </div>

      <div class="mt-10">
        <h3 class="text-2xl font-bold text-gray-950 dark:text-white">Maths Courses</h3>
        <div class="mt-5 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {
            mathsCourseCards.map((course) => (
              <article class={courseCardClass}>
                <h3 class="text-xl font-bold text-gray-950 dark:text-white">{course.title}</h3>
                <p class="mt-3 text-base leading-7 text-muted dark:text-slate-300">{course.description}</p>
                <ul class="mt-4 space-y-2 text-base leading-7 text-muted dark:text-slate-300">
                  {course.bullets.map((item) => (
                    <li class="flex gap-2">
                      <span class="mt-2 size-1.5 rounded-full bg-secondary" aria-hidden="true" />
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
                <div class="mt-auto pt-5">
                  <a class="btn-secondary w-full justify-center sm:w-auto" href={getPermalink(`/${course.slug}`)}>
                    {course.buttonText}
                  </a>
                </div>
              </article>
            ))
          }
        </div>
      </div>

      <div class="mt-12">
        <h3 class="text-2xl font-bold text-gray-950 dark:text-white">Coding Courses</h3>
        <div class="mt-5 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {
            codingCourseCards.map((course) => (
              <article class={courseCardClass}>
                <h3 class="text-xl font-bold text-gray-950 dark:text-white">{course.title}</h3>
                <p class="mt-3 text-base leading-7 text-muted dark:text-slate-300">{course.description}</p>
                <ul class="mt-4 space-y-2 text-base leading-7 text-muted dark:text-slate-300">
                  {course.bullets.map((item) => (
                    <li class="flex gap-2">
                      <span class="mt-2 size-1.5 rounded-full bg-secondary" aria-hidden="true" />
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
                <div class="mt-auto pt-5">
                  <a class="btn-secondary w-full justify-center sm:w-auto" href={getPermalink(`/${course.slug}`)}>
                    {course.buttonText}
                  </a>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="bg-brand-soft py-14 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Support Levels</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white md:text-4xl">
          Then Choose Your Support Level
        </h2>
        <p class="mt-4 text-lg leading-8 text-muted dark:text-slate-300">
          Choose between self-paced course access with messaging support, or add live one-to-one tutoring each month.
        </p>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {
          onlinePackages.map((item) => (
            <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800">
              <h3 class="text-xl font-bold text-gray-950 dark:text-white">{item.title} Package</h3>
              <p class="mt-3 text-muted dark:text-slate-300">{item.detail}</p>
              <p class="mt-6 text-3xl font-extrabold text-primary">{item.price}</p>
              {item.note && <p class="mt-3 text-sm font-semibold text-secondary dark:text-teal-200">{item.note}</p>}
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-white py-14 dark:bg-slate-900">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Included</p>
          <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white">
            What Every Support Level Includes
          </h2>
          <p class="mt-4 text-lg leading-8 text-muted dark:text-slate-300">
            Every support level is designed to give students structured course access, clear resources and a simple way
            to ask for help.
          </p>
        </div>
        <ul class="grid gap-3 sm:grid-cols-2">
          {
            overviewPackageIncludes.map((item) => (
              <li class="rounded-lg border border-gray-200 bg-gray-50 p-4 text-base font-medium leading-7 text-gray-800 dark:border-gray-700 dark:bg-slate-800 dark:text-slate-200">
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-brand-soft py-10 dark:bg-slate-900">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800">
        <div class="grid gap-5 md:grid-cols-[1fr_auto] md:items-center">
          <div>
            <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Also Available</p>
            <h2 class="mt-2 text-2xl font-bold text-gray-950 dark:text-white">Online Group Classes</h2>
            <p class="mt-3 text-base leading-7 text-muted dark:text-slate-300">
              Small online group classes may be available for GCSE Maths and beginner coding. These are suitable for
              students who want regular support at a lower cost than one-to-one tuition.
            </p>
            <ul class="mt-4 grid gap-2 text-base leading-7 text-muted dark:text-slate-300 sm:grid-cols-2">
              <li>Small groups</li>
              <li>Guided practice</li>
              <li>Topic revision</li>
              <li>Exam-style questions</li>
            </ul>
          </div>
          <a class="btn-secondary justify-center" href={groupClassesUrl}>Ask About Group Classes</a>
        </div>
      </div>
    </div>
  </section>

  <FAQs
    title="Online Courses FAQs"
    columns={2}
    items={[
      {
        title: 'Which levels can be taught online?',
        description:
          'Online maths tuition is available for Year 6, KS3, GCSE, IGCSE, Functional Skills and A-Level. Beginner Python coding lessons are also available for students aged 10+.',
      },
      {
        title: 'How long is each lesson?',
        description: 'Each live online booking is a 55-minute session, for both maths and coding courses.',
      },
      {
        title: 'Does online tuition include exam practice?',
        description:
          'Yes. GCSE, IGCSE, A-Level and Functional Skills lessons can include topic revision, past papers and exam-style questions.',
      },
      {
        title: 'Is coding tuition the same format as maths tuition?',
        description:
          'Yes. Coding lessons follow the same structure - a diagnostic check, guided practice, and a worksheet or coding task after each session.',
      },
      {
        title: 'What does the student need?',
        description:
          'A reliable internet connection, a quiet place to work, and a device suitable for video lessons. A laptop is recommended for coding lessons.',
      },
      ...packageFaqs,
    ]}
  />

  <CallToAction
    title="Ready to Get Started?"
    subtitle="Register your interest and I will get back to you with the most suitable support option."
    actions={[
      {
        variant: 'primary',
        text: ctaLabels.onlineTuitionInterest,
        href: registerInterestUrl,
        icon: 'tabler:calendar-check',
      },
    ]}
  />
</Layout>
