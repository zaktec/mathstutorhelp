---
import Layout from '~/layouts/PageLayout.astro';

import HomeHero from '~/components/widgets/HomeHero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Maths Tuition in Manchester & Online',
  description:
    'GCSE, IGCSE, KS3, Functional Skills and A-Level maths support in Manchester and online from a qualified, DBS-checked teacher.',
  ignoreTitleTemplate: true,
};

const consultationBookingUrl = 'https://calendar.app.google/VJ6tgEKfsUZAncDe9';
const groupClassInterestUrl = 'https://hai-bl.com/onboarding/interest-form';
---

<Layout metadata={metadata}>
  <HomeHero consultationBookingUrl={consultationBookingUrl} tuitionOptionsUrl="/maths-tuition/" />

  <Features
    id="who-for"
    tagline="Who It Is For"
    title="Who MathsTutorHelp Is For"
    subtitle="Support is suitable for students who need maths to feel clearer, more structured and less stressful."
    columns={3}
    items={[
      {
        title: 'Students feeling anxious or stuck',
        description: 'Calm explanations help students start again without feeling judged or rushed.',
        icon: 'tabler:mood-smile',
      },
      {
        title: 'GCSE and IGCSE exam preparation',
        description: 'Lessons focus on the topics, question styles and working-out skills needed for exams.',
        icon: 'tabler:file-pencil',
      },
      {
        title: 'Foundation Grade 4/5 students',
        description: 'Clear methods and regular practice help students aim for secure Grade 4 or Grade 5 outcomes.',
        icon: 'tabler:certificate',
      },
      {
        title: 'Higher Grade 6-9 students',
        description: 'Students pushing higher get challenge, exam technique and support with harder problem solving.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'Students needing routine',
        description: 'Regular tuition gives students structure, accountability and a clear plan for practice.',
        icon: 'tabler:calendar-check',
      },
      {
        title: 'Online or Manchester-based support',
        description: 'Families can choose online lessons, local one-to-one tuition or GCSE group classes.',
        icon: 'tabler:map-2',
      },
    ]}
  />

  <Features
    id="tuition-options"
    tagline="Maths Tuition Services"
    title="Tuition for the Stage Your Child Is At"
    subtitle="Support is available for school students, exam candidates and learners who need practical maths confidence."
    columns={3}
    items={[
      {
        title: 'GCSE Maths Support',
        description:
          'Topic-by-topic revision, exam question practice and clear methods for foundation and higher tier GCSE maths.',
        icon: 'tabler:math-function',
        callToAction: { text: 'View Tuition Options', href: '/maths-tuition/' },
      },
      {
        title: 'IGCSE Maths Tuition',
        description:
          'Structured support for IGCSE students, including algebra, geometry, graphs, statistics and exam technique.',
        icon: 'tabler:calculator',
        callToAction: { text: 'View Tuition Options', href: '/maths-tuition/' },
      },
      {
        title: 'A-Level Maths Tuition',
        description:
          'Focused help with pure maths, mechanics and statistics, with careful attention to reasoning and problem solving.',
        icon: 'tabler:chart-line',
        callToAction: { text: 'View Tuition Options', href: '/maths-tuition/' },
      },
      {
        title: 'Functional Skills Maths',
        description:
          'Practical maths support for learners who need clearer methods and confidence with everyday numeracy.',
        icon: 'tabler:clipboard-check',
        callToAction: { text: 'View Tuition Options', href: '/maths-tuition/' },
      },
      {
        title: 'Online Maths Tuition',
        description:
          'Interactive online lessons with worked examples, shared resources and regular exam-style practice.',
        icon: 'tabler:video',
        callToAction: { text: 'View Tuition Options', href: '/online-tuitions/' },
      },
      {
        title: 'Group Classes in Manchester',
        description:
          'Small group maths classes for students who benefit from structured teaching and regular guided practice.',
        icon: 'tabler:users-group',
        callToAction: { text: 'Register Your Interest', href: groupClassInterestUrl },
      },
    ]}
  />

  <Content
    id="group-classes"
    tagline="GCSE Group Classes"
    title="Small GCSE Group Maths Classes in Levenshulme"
    items={[
      {
        title: 'GCSE Higher Maths Classes',
        description:
          'Best for students aiming for grades 6-9, with topic revision, exam technique and guided practice.',
        icon: 'tabler:chart-line',
        callToAction: {
          text: 'View Tuition Options',
          href: '/gcse-revision-class-higher-manchester/',
        },
      },
      {
        title: 'GCSE Foundation Tutoring',
        description:
          'Best for students aiming to secure grades 4-5 with clear methods and confidence-building practice.',
        icon: 'tabler:certificate',
        callToAction: {
          text: 'View Tuition Options',
          href: '/gcse-foundation-maths-tutoring-club-2025/',
        },
      },
      {
        title: '£20 group sessions',
        description: 'An affordable route for regular GCSE maths support, revision and exam-style practice.',
        icon: 'tabler:coin-pound',
      },
      {
        title: 'Limited places',
        description: 'Register your interest to ask about current availability or join the waiting list.',
        icon: 'tabler:users-group',
      },
    ]}
  >
    <Fragment slot="image">
      <div class="space-y-4">
        <img
          class="mx-auto w-full rounded-lg bg-gray-500 shadow-lg"
          src="https://images.unsplash.com/photo-1577896851231-70ef18881754?auto=format&fit=crop&w=1400&q=80"
          alt="Students learning together in a classroom"
          width="500"
          height="500"
          loading="lazy"
        />
        <div
          class="rounded-lg border border-gray-200 bg-white p-5 text-center shadow-sm dark:border-gray-700 dark:bg-slate-800"
        >
          <p class="text-lg font-bold text-gray-900 dark:text-white">Interested in GCSE group classes?</p>
          <p class="mt-2 text-sm text-muted dark:text-slate-300">
            Register your interest to ask about current places or join the waiting list.
          </p>
          <a class="btn-primary mt-4 w-full sm:w-auto" href={groupClassInterestUrl}>Register Your Interest</a>
        </div>
      </div>
    </Fragment>

    <Fragment slot="content">
      <p>
        Group classes are a strong option for GCSE students who need routine, motivation and exam-focused practice
        without the cost of full one-to-one tuition. Classes are based in Levenshulme and taught in a calm, supportive
        setting.
      </p>
    </Fragment>
  </Content>

  <Content
    isReversed
    tagline="How Lessons Work"
    title="Clear Explanations, Regular Practice and Steady Progress"
    items={[
      {
        title: 'Find the gaps',
        description: 'The first sessions identify weak topics, target grade and the exam board requirements.',
      },
      {
        title: 'Build understanding',
        description: 'Each topic is taught step by step, with examples that make the method easier to remember.',
      },
      {
        title: 'Practise exam questions',
        description: 'Students work through exam-style questions so they can apply methods and show working clearly.',
      },
      {
        title: 'Review progress',
        description: 'Parents get a clear sense of what has improved and what the student should practise next.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1635070041078-e363dbe005cb?auto=format&fit=crop&w=1400&q=80',
      alt: 'Maths working and formulas on a study desk',
    }}
  >
    <Fragment slot="content">
      <p>
        The aim is not just to get through homework. Students learn why a method works, when to use it and how to show
        working clearly in exams.
      </p>
    </Fragment>
  </Content>

  <Features
    id="prices"
    tagline="Prices"
    title="Simple Tuition Options"
    subtitle="Choose the lesson format that best fits your child, timetable and goals."
    columns={3}
    items={[
      {
        title: 'One-to-one tuition - £30/hr',
        description:
          'Personalised GCSE, IGCSE, A-Level or Functional Skills support. Best for targeted help and faster feedback.',
        icon: 'tabler:user',
        callToAction: { text: 'Book a Free Consultation', href: consultationBookingUrl },
      },
      {
        title: 'Small group classes - £20',
        description:
          'Structured Manchester-based group lessons for students who like learning with others and regular practice.',
        icon: 'tabler:users',
        callToAction: { text: 'Register Your Interest', href: groupClassInterestUrl },
      },
      {
        title: 'Online lessons - £25/hr',
        description:
          'Flexible online maths tuition with the same clear teaching, guided examples and exam question practice.',
        icon: 'tabler:device-desktop',
        callToAction: { text: 'Book a Free Consultation', href: consultationBookingUrl },
      },
    ]}
  />

  <Features
    id="exam-boards"
    tagline="Exam Boards"
    title="Exam Boards Supported"
    subtitle="GCSE Maths support is available for Edexcel, AQA and OCR exam boards. IGCSE support is also available for students following Pearson Edexcel or Cambridge IGCSE Maths."
    columns={3}
    items={[
      {
        title: 'GCSE Maths',
        description: "Support for Edexcel, AQA and OCR, adapted to the student's tier and target grade.",
        icon: 'tabler:file-certificate',
      },
      {
        title: 'IGCSE Maths',
        description: 'Support for Pearson Edexcel IGCSE and Cambridge IGCSE Maths specifications.',
        icon: 'tabler:book-2',
      },
      {
        title: 'Target-grade planning',
        description: 'Lessons are matched to Foundation Grade 4/5 goals or Higher Grade 6-9 ambitions.',
        icon: 'tabler:target-arrow',
      },
    ]}
  />

  <Testimonials
    tagline="What Parents Can Expect"
    title="Calm Teaching, Regular Practice and Clear Feedback"
    subtitle="Families can expect calm teaching, regular practice and clear feedback so students know what to improve next."
    testimonials={[
      {
        title: 'Clearer confidence with difficult topics',
        testimonial:
          'Students are supported to attempt challenging topics step by step, especially when algebra, fractions or problem-solving questions feel overwhelming.',
        name: 'Confidence support',
        job: 'Confidence building',
      },
      {
        title: 'Better exam technique',
        testimonial:
          'Lessons focus on showing working clearly, understanding where marks are gained and approaching exam-style questions with a steady method.',
        name: 'Exam preparation',
        job: 'GCSE preparation',
      },
      {
        title: 'A useful routine for progress',
        testimonial:
          'Regular practice, simple homework targets and parent-friendly feedback help families understand what is improving and what still needs work.',
        name: 'Steady progress',
        job: 'Steady progress',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-brand-soft dark:bg-transparent"></div>
    </Fragment>
  </Testimonials>

  <Content
    tagline="Also Available"
    title="Summer Coding Club"
    callToAction={{
      text: 'View Tuition Options',
      href: '/manchestersummercodingclub/',
      icon: 'tabler:chevron-right',
    }}
    items={[
      {
        title: 'Python for ages 13-17',
        description: 'Beginner-friendly coding lessons where students learn Python and build practical projects.',
        icon: 'tabler:code',
      },
      {
        title: 'Small summer group',
        description: 'A limited-place Manchester coding course for students interested in maths, logic and technology.',
        icon: 'tabler:users-group',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1515879218367-8466d910aaa4?auto=format&fit=crop&w=1400&q=80',
      alt: 'Student learning Python coding on a laptop',
    }}
  >
    <Fragment slot="content">
      <p>
        The Summer Coding Club is an additional option for students who want to learn Python, build practical projects
        and develop stronger problem-solving skills.
      </p>
    </Fragment>
  </Content>

  <FAQs
    title="Frequently Asked Questions"
    subtitle="Quick answers for parents comparing maths tuition options."
    tagline="FAQs"
    columns={2}
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Do you teach online or in person?',
        description:
          'Both options are available. In-person tuition is Manchester-based, and online lessons are available for students outside the local area.',
      },
      {
        title: 'Which levels do you teach?',
        description:
          'Tuition is available for KS3, GCSE, IGCSE, A-Level and Functional Skills maths, including exam preparation and topic support.',
      },
      {
        title: 'Can lessons help with exam technique?',
        description:
          'Yes. Lessons include past paper practice, mark scheme guidance and advice on how to show working clearly.',
      },
      {
        title: 'How do I book?',
        description:
          'Register your interest for group class places or request a free consultation. You can explain the student level, goals and preferred lesson format.',
      },
      {
        title: 'How much are group classes?',
        description: 'Group sessions are £20. Online tutoring is £25/hr and in-person one-to-one tutoring is £30/hr.',
      },
      {
        title: 'Where are group classes held?',
        description:
          'GCSE group classes are based in Levenshulme, Manchester. Register your interest to ask about current spaces.',
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Register Your Interest',
        href: groupClassInterestUrl,
        icon: 'tabler:calendar-check',
      },
      { text: 'Book a Free Consultation', href: consultationBookingUrl },
    ]}
  >
    <Fragment slot="title">Ready to Find the Right Maths Support?</Fragment>

    <Fragment slot="subtitle">
      Tell us the student level, target grade and the areas that feel difficult. We will help you choose between
      one-to-one tuition, online lessons or a GCSE group class.
    </Fragment>
  </CallToAction>
</Layout>
