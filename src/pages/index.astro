---
import Layout from '~/layouts/PageLayout.astro';

import HomeHero from '~/components/widgets/HomeHero.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getAsset, getPermalink } from '~/utils/permalinks';
import { bookingLinks, ctaLabels, tuitionPrices } from '~/utils/siteDetails';

const metadata = {
  title: 'Maths Tutor Manchester | GCSE, IGCSE & A-Level Maths',
  description:
    'Manchester maths tutor for GCSE, IGCSE, KS3, Functional Skills and A-Level. Small GCSE classes in Levenshulme plus online maths tuition.',
  ignoreTitleTemplate: true,
};

const consultationBookingUrl = bookingLinks.freeConsultation;
const groupClassInterestUrl = bookingLinks.groupClassInterest;
const gcseClassesUrl = getPermalink('/gcse-classes');
const foundationClassUrl = getPermalink('/gcse-foundation-maths-tutoring-club-2025');
const higherClassUrl = getPermalink('/gcse-revision-class-higher-manchester');
const onlineTuitionUrl = getPermalink('/online-tuition');
const levenshulmeTutorUrl = getPermalink('/maths-tutor-levenshulme');
const gcseTutorManchesterUrl = getPermalink('/gcse-maths-tutor-manchester');
const compactSection = { container: 'py-8 md:py-10 lg:py-12' };

const priceOptions = [
  {
    label: 'One-to-one tuition',
    price: tuitionPrices.oneToOne.amount,
    unit: tuitionPrices.oneToOne.unit,
    description: 'Personalised GCSE, IGCSE, A-Level or Functional Skills support.',
    action: 'Ask About One-to-One Tuition',
    href: consultationBookingUrl,
  },
  {
    label: 'Small group classes',
    price: tuitionPrices.smallGroup.amount,
    unit: tuitionPrices.smallGroup.unit,
    description: 'Structured Manchester-based GCSE lessons with regular practice.',
    action: ctaLabels.groupClassInterest,
    href: groupClassInterestUrl,
    featured: true,
  },
  {
    label: 'Online tuition',
    price: tuitionPrices.online.amount,
    unit: tuitionPrices.online.unit,
    description: 'Live one-to-one online maths tuition. Course packages are separate.',
    action: 'Ask About Online Tuition',
    href: consultationBookingUrl,
  },
];
---

<Layout metadata={metadata}>
  <HomeHero groupClassInterestUrl={groupClassInterestUrl} />

  <Features2
    id="meet-your-tutor"
    tagline="Meet Your Tutor"
    title="Qualified Maths Support From Mr Sheraz"
    subtitle="Qualified, DBS-checked maths teacher based in Levenshulme, supporting students across Manchester and online."
    columns={3}
    classes={compactSection}
    items={[
      {
        title: 'Clear teaching',
        description: 'Step-by-step methods for school topics and exam questions.',
        icon: 'tabler:chalkboard',
      },
      {
        title: 'Patient support',
        description: 'Students can ask questions and rebuild confidence.',
        icon: 'tabler:mood-smile',
      },
      {
        title: 'Practical next steps',
        description: 'Lessons focus on the topics and grades that matter most.',
        icon: 'tabler:list-check',
      },
    ]}
  />

  <Content
    id="group-classes"
    tagline="GCSE Group Classes"
    title="Small GCSE Group Maths Classes in Levenshulme"
    classes={compactSection}
    items={[
      {
        title: 'GCSE Higher Maths Classes',
        description: 'For students aiming for grades 6-9.',
        icon: 'tabler:chart-line',
        callToAction: {
          text: 'View Higher Class',
          href: higherClassUrl,
        },
      },
      {
        title: 'GCSE Foundation Tutoring',
        description: 'For students aiming to secure grades 4-5.',
        icon: 'tabler:certificate',
        callToAction: {
          text: 'View Foundation Class',
          href: foundationClassUrl,
        },
      },
      {
        title: `${tuitionPrices.smallGroup.display} group sessions`,
        description: 'Regular GCSE maths support at a lower cost than one-to-one tuition.',
        icon: 'tabler:coin-pound',
      },
      {
        title: 'Limited places',
        description: 'Ask about availability or join the waiting list.',
        icon: 'tabler:users-group',
      },
    ]}
  >
    <Fragment slot="image">
      <div class="space-y-4">
        <img
          class="mx-auto w-full rounded-lg bg-gray-500 shadow-lg"
          src={getAsset('/images/gallery/classroom-circle-theorems.jpeg')}
          alt="GCSE Maths board work from a real class"
          width="500"
          height="500"
          loading="lazy"
        />
        <div
          class="rounded-lg border border-gray-200 bg-white p-5 text-center shadow-sm dark:border-gray-700 dark:bg-slate-800"
        >
          <p class="text-lg font-bold text-gray-900 dark:text-white">Interested in GCSE group classes?</p>
          <p class="mt-2 text-sm text-muted dark:text-slate-300">
            Places are limited and allocated on a first-come, first-served basis.
          </p>
          <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:justify-center">
            <a class="btn-primary w-full sm:w-auto" href={groupClassInterestUrl}>{ctaLabels.groupClassInterest}</a>
            <a class="btn-secondary w-full sm:w-auto" href={gcseClassesUrl}>View GCSE Classes</a>
          </div>
        </div>
      </div>
    </Fragment>

    <Fragment slot="content">
      <p>
        Small GCSE groups give students weekly routine, clear explanations and exam-style practice in a calm, supportive
        setting.
      </p>
    </Fragment>
  </Content>

  <Features
    id="tuition-options"
    tagline="Tuition Services"
    title="Tuition for the Stage Your Child Is At"
    subtitle="GCSE, IGCSE, A-Level, Functional Skills, online tuition and local classes."
    columns={4}
    classes={compactSection}
    items={[
      {
        title: 'GCSE Maths Support',
        description: 'Foundation and Higher tier maths with exam-style practice.',
        icon: 'tabler:math-function',
        callToAction: { text: 'GCSE Maths Tutor Manchester', href: gcseTutorManchesterUrl },
      },
      {
        title: 'IGCSE Maths Tuition',
        description: 'Structured IGCSE help with key topics and exam technique.',
        icon: 'tabler:calculator',
      },
      {
        title: 'A-Level Maths Tuition',
        description: 'Pure maths, mechanics, statistics and problem solving.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'Online Tuition and Courses',
        description: 'Live online maths tuition is £25/hr. Courses use separate packages.',
        icon: 'tabler:video',
        callToAction: { text: 'View Online Options', href: onlineTuitionUrl },
      },
    ]}
  />

  <section class="bg-white py-8 dark:bg-slate-900 md:py-10 lg:py-12">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="rounded-lg border border-gray-200 bg-brand-soft p-6 dark:border-gray-700 dark:bg-slate-800">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Local Areas</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950 dark:text-white">
          Maths Tuition in Levenshulme and Manchester
        </h2>
        <p class="mt-3 text-base leading-7 text-muted dark:text-slate-300">
          Based in Levenshulme, supporting families across Manchester, Longsight, Burnage, Didsbury and Stockport.
        </p>
        <div class="mt-5 flex flex-col gap-3 sm:flex-row">
          <a class="btn-secondary justify-center" href={levenshulmeTutorUrl}>Maths Tutor Levenshulme</a>
          <a class="btn-secondary justify-center" href={gcseTutorManchesterUrl}>GCSE Maths Tutor Manchester</a>
        </div>
      </div>
    </div>
  </section>

  <section id="prices" class="bg-brand-soft py-8 dark:bg-slate-900 md:py-10 lg:py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Prices</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white md:text-4xl">
          Simple Tuition Options
        </h2>
      </div>

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {
          priceOptions.map((option) => (
            <article
              class={`relative rounded-lg border bg-white p-6 shadow-sm dark:bg-slate-800 ${
                option.featured
                  ? 'border-primary ring-2 ring-primary/20 dark:border-teal-300'
                  : 'border-gray-200 dark:border-gray-700'
              }`}
            >
              {option.featured && (
                <span class="absolute right-4 top-4 rounded-full bg-primary px-3 py-1 text-xs font-bold text-white">
                  Popular
                </span>
              )}
              <h3 class="pr-20 text-xl font-bold text-gray-950 dark:text-white">{option.label}</h3>
              <div class="mt-5 rounded-lg bg-brand-soft p-5 dark:bg-slate-900">
                <p class="flex items-end gap-2 text-primary">
                  <span class="text-5xl font-extrabold tracking-tight">{option.price}</span>
                  <span class="pb-2 text-sm font-bold text-gray-700 dark:text-slate-200">{option.unit}</span>
                </p>
              </div>
              <p class="mt-5 min-h-20 text-sm leading-6 text-muted dark:text-slate-300">{option.description}</p>
              <a class="btn-secondary mt-5 w-full justify-center" href={option.href}>
                {option.action}
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <FAQs
    title="Frequently Asked Questions"
    subtitle="Quick answers for parents."
    tagline="FAQs"
    columns={2}
    classes={{ container: 'max-w-6xl py-8 md:py-10 lg:py-12' }}
    items={[
      {
        title: 'Do you teach online or in person?',
        description: 'Yes. In-person tuition is Manchester-based, and online one-to-one tuition is £25/hr.',
      },
      {
        title: 'Which levels do you teach?',
        description: 'KS3, GCSE, IGCSE, A-Level and Functional Skills maths.',
      },
      {
        title: 'How do I book?',
        description: 'Register interest for group classes or request a free consultation.',
      },
      {
        title: 'How much are group classes?',
        description: `Group sessions are ${tuitionPrices.smallGroup.display}. Online one-to-one tuition is ${tuitionPrices.online.display}.`,
      },
    ]}
  />

  <CallToAction
    classes={compactSection}
    actions={[
      {
        variant: 'primary',
        text: ctaLabels.groupClassInterest,
        href: groupClassInterestUrl,
        icon: 'tabler:calendar-check',
      },
      { text: ctaLabels.freeConsultation, href: consultationBookingUrl },
    ]}
  >
    <Fragment slot="title">Ready to Find the Right Maths Support?</Fragment>

    <Fragment slot="subtitle">
      Tell us the student level and target grade. We will help you choose the best option.
    </Fragment>
  </CallToAction>
</Layout>
