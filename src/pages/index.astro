---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Maths Tutor in Manchester for GCSE, IGCSE and A-Level',
  description:
    'Online and in-person maths tuition in Manchester for GCSE, IGCSE, A-Level and Functional Skills students.',
  ignoreTitleTemplate: true,
};

const consultationBookingUrl = 'https://calendar.app.google/VJ6tgEKfsUZAncDe9';
---

<Layout metadata={metadata}>
  <Hero
    tagline="Maths Tutor Help"
    actions={[
      {
        variant: 'primary',
        text: 'Book a Free Consultation',
        href: consultationBookingUrl,
        icon: 'tabler:calendar-check',
      },
      { text: 'View Tuition Options', href: '#tuition-options' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1509062522246-3755977927d7?auto=format&fit=crop&w=1800&q=80',
      alt: 'Student receiving maths support during a lesson',
    }}
  >
    <Fragment slot="title">
      Maths Tutor in Manchester for <span class="text-accent dark:text-white">GCSE, IGCSE and A-Level</span>
    </Fragment>

    <Fragment slot="subtitle">
      Online and in-person maths tuition with clear explanations, exam practice and personalised support from an
      experienced, DBS-checked teacher.
    </Fragment>
  </Hero>

  <Content
    id="group-classes"
    tagline="Group Classes"
    title="Group Maths Classes in Levenshulme, Manchester"
    callToAction={{
      text: 'Ask About Group Classes',
      href: '/contact',
      icon: 'tabler:chevron-right',
    }}
    items={[
      {
        title: 'GCSE Higher Maths Classes',
        description:
          'Manchester group classes for GCSE higher students aiming for grades 6-9, with focused topic revision and exam-style practice.',
        icon: 'tabler:chart-line',
        callToAction: {
          text: 'View Higher class',
          href: '/gcse-revision-class-higher-manchester/',
        },
      },
      {
        title: 'GCSE Foundation Tutoring',
        description:
          'Supportive GCSE foundation maths tutoring for students working towards grades 4-5, with clear methods and regular practice.',
        icon: 'tabler:certificate',
        callToAction: {
          text: 'View Foundation class',
          href: '/gcse-foundation-maths-tutoring-club-2025/',
        },
      },
      {
        title: 'Summer Coding Course',
        description:
          'Python coding course in Manchester for ages 13-17, designed for students who want practical programming skills.',
        icon: 'tabler:code',
        callToAction: {
          text: 'View Python course',
          href: '/manchestersummercodingclub/',
        },
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1577896851231-70ef18881754?auto=format&fit=crop&w=1400&q=80',
      alt: 'Students learning together in a classroom',
    }}
  >
    <Fragment slot="content">
      <p>
        Group classes are available in Levenshulme, Manchester for GCSE maths students and young coders who want
        structured teaching in a focused, supportive setting. Places can be discussed during a free consultation.
      </p>
    </Fragment>
  </Content>

  <Features
    id="trust"
    title="Trusted Maths Support for Manchester Families"
    subtitle="Calm, structured tuition for students who need stronger understanding, better exam technique and more confidence."
    columns={3}
    items={[
      {
        title: 'Qualified teacher',
        description: 'Lessons are led by an experienced teacher who understands the UK maths curriculum.',
        icon: 'tabler:school',
      },
      {
        title: 'DBS checked',
        description: 'Professional, parent-focused support with safeguarding and reliability at the centre.',
        icon: 'tabler:shield-check',
      },
      {
        title: "15+ years' experience",
        description: 'Clear guidance built from years of helping students prepare for exams and close knowledge gaps.',
        icon: 'tabler:award',
      },
      {
        title: 'Online and in person',
        description: 'Flexible lesson options for Manchester families and students who prefer online tuition.',
        icon: 'tabler:device-laptop',
      },
      {
        title: 'Exam-focused practice',
        description: 'Past paper work, topic revision and step-by-step methods for GCSE, IGCSE and A-Level.',
        icon: 'tabler:file-check',
      },
      {
        title: 'Personalised lessons',
        description: 'Tuition is adapted to the student, from confidence building to higher-grade preparation.',
        icon: 'tabler:user-check',
      },
    ]}
  />

  <Features
    id="tuition-options"
    tagline="Maths Tuition Services"
    title="Tuition for the Stage Your Child Is At"
    subtitle="Support is available for school students, exam candidates and learners who need practical maths confidence."
    columns={3}
    items={[
      {
        title: 'GCSE Maths Support',
        description:
          'Topic-by-topic revision, exam question practice and clear methods for foundation and higher tier GCSE maths.',
        icon: 'tabler:math-function',
      },
      {
        title: 'IGCSE Maths Tuition',
        description:
          'Structured support for IGCSE students, including algebra, geometry, graphs, statistics and exam technique.',
        icon: 'tabler:calculator',
      },
      {
        title: 'A-Level Maths Tuition',
        description:
          'Focused help with pure maths, mechanics and statistics, with careful attention to reasoning and problem solving.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'Functional Skills Maths',
        description:
          'Practical maths support for learners who need clearer methods and confidence with everyday numeracy.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Online Maths Tuition',
        description:
          'Interactive online lessons with worked examples, shared resources and regular exam-style practice.',
        icon: 'tabler:video',
      },
      {
        title: 'Group Classes in Manchester',
        description:
          'Small group maths classes for students who benefit from structured teaching and regular guided practice.',
        icon: 'tabler:users-group',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features>

  <Content
    isReversed
    tagline="How Lessons Work"
    title="Clear Explanations, Regular Practice and Steady Progress"
    items={[
      {
        title: 'Find the gaps',
        description: 'The first sessions identify weak topics, confidence issues and the exam board requirements.',
      },
      {
        title: 'Build understanding',
        description: 'Each topic is taught step by step, with examples that make the method easier to remember.',
      },
      {
        title: 'Practise exam questions',
        description: 'Students work through exam-style questions so they can apply methods under real conditions.',
      },
      {
        title: 'Review progress',
        description: 'Parents get a clear sense of what has improved and what the student should practise next.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1635070041078-e363dbe005cb?auto=format&fit=crop&w=1400&q=80',
      alt: 'Maths working and formulas on a study desk',
    }}
  >
    <Fragment slot="content">
      <p>
        The aim is not just to get through homework. Students learn why a method works, when to use it and how to show
        working clearly in exams.
      </p>
    </Fragment>
  </Content>

  <Features
    id="prices"
    tagline="Prices"
    title="Simple Tuition Options"
    subtitle="Choose the lesson format that best fits your child, timetable and goals."
    columns={3}
    items={[
      {
        title: 'One-to-one tuition',
        description:
          'Personalised GCSE, IGCSE, A-Level or Functional Skills support. Best for targeted help and faster feedback.',
        icon: 'tabler:user',
        callToAction: { text: 'Ask about availability', href: '/contact' },
      },
      {
        title: 'Small group classes',
        description:
          'Structured Manchester-based group lessons for students who like learning with others and regular practice.',
        icon: 'tabler:users',
        callToAction: { text: 'View group options', href: '/contact' },
      },
      {
        title: 'Online lessons',
        description:
          'Flexible online maths tuition with the same clear teaching, guided examples and exam question practice.',
        icon: 'tabler:device-desktop',
        callToAction: { text: 'Book a consultation', href: consultationBookingUrl },
      },
    ]}
  />

  <Testimonials
    tagline="What Parents Say"
    title="Support That Feels Clear and Reassuring"
    subtitle="Real testimonials can be added here when you are ready. These placeholders show the right tone for the section."
    testimonials={[
      {
        title: 'Confidence improved',
        testimonial:
          'My child finally understands topics that used to feel impossible. The explanations are calm, clear and easy to follow.',
        name: 'Parent of GCSE student',
        job: 'Manchester',
      },
      {
        title: 'Excellent exam preparation',
        testimonial:
          'The lessons focused on the exact areas that needed work, with lots of exam-style practice and helpful feedback.',
        name: 'Parent of A-Level student',
        job: 'Online tuition',
      },
      {
        title: 'Patient and professional',
        testimonial:
          'Mr Cheema is patient, organised and very good at explaining maths in a way that makes sense.',
        name: 'Parent review',
        job: 'Maths Tutor Help',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Testimonials>

  <FAQs
    title="Frequently Asked Questions"
    subtitle="Quick answers for parents comparing maths tuition options."
    tagline="FAQs"
    columns={2}
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Do you teach online or in person?',
        description:
          'Both options are available. In-person tuition is Manchester-based, and online lessons are available for students outside the local area.',
      },
      {
        title: 'Which levels do you teach?',
        description:
          'Tuition is available for GCSE, IGCSE, A-Level and Functional Skills maths, including exam preparation and topic support.',
      },
      {
        title: 'Can lessons help with exam technique?',
        description:
          'Yes. Lessons include past paper practice, mark scheme guidance and advice on how to show working clearly.',
      },
      {
        title: 'How do I book?',
        description:
          'Use the contact page to request a free consultation. You can explain the student level, goals and preferred lesson format.',
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Book a Free Consultation',
        href: consultationBookingUrl,
        icon: 'tabler:calendar-check',
      },
      { text: 'View Tuition Options', href: '#tuition-options' },
    ]}
  >
    <Fragment slot="title">Ready to Get Maths Support?</Fragment>

    <Fragment slot="subtitle">
      Tell us the student level, exam board and the areas that feel difficult. We will help you choose the right next
      step.
    </Fragment>
  </CallToAction>
</Layout>
