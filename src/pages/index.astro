---
import Layout from '~/layouts/PageLayout.astro';

import HomeHero from '~/components/widgets/HomeHero.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';
import { bookingLinks, ctaLabels, tuitionPrices } from '~/utils/siteDetails';

const metadata = {
  title: 'MathsTutorHelp | Maths Tutor Manchester',
  description:
    'Qualified maths tutor in Manchester offering GCSE, IGCSE, KS3 and A-Level tuition. Online lessons and small-group classes in Levenshulme.',
  ignoreTitleTemplate: true,
};

const consultationBookingUrl = bookingLinks.freeConsultation;
const groupClassInterestUrl = bookingLinks.groupClassInterest;
const gcseClassesUrl = getPermalink('/gcse-classes');
const onlineTuitionUrl = getPermalink('/online-tuition');
const codingCourseUrl = getPermalink('/manchestersummercodingclub');
const pricingUrl = getPermalink('/pricing');
const compactSection = { container: 'py-8 md:py-10 lg:py-12' };

const priceOptions = [
  {
    label: 'One-to-one tuition',
    price: tuitionPrices.oneToOne.amount,
    unit: tuitionPrices.oneToOne.unit,
    description: 'Personalised maths support.',
    action: 'Ask About One-to-One Tuition',
    href: consultationBookingUrl,
  },
  {
    label: 'Small group classes',
    price: tuitionPrices.smallGroup.amount,
    unit: tuitionPrices.smallGroup.unit,
    description: 'GCSE classes in Levenshulme.',
    action: 'Register Interest',
    href: groupClassInterestUrl,
    featured: true,
  },
  {
    label: 'Online tuition',
    price: tuitionPrices.online.amount,
    unit: tuitionPrices.online.unit,
    description: 'Live online maths lessons.',
    action: 'Ask About Online Tuition',
    href: consultationBookingUrl,
  },
];
---

<Layout metadata={metadata}>
  <HomeHero groupClassInterestUrl={groupClassInterestUrl} />

  <Features2
    id="choose-your-support"
    tagline="Tuition Options"
    title="Choose Your Support"
    subtitle="Pick the route that best matches your child: group GCSE Maths tuition, private lessons, online learning or coding support."
    columns={4}
    classes={compactSection}
    items={[
      {
        title: 'GCSE Group Classes',
        description:
          'Small GCSE Foundation and Higher classes in Levenshulme, Manchester, with clear teaching and regular exam practice.',
        icon: 'tabler:users-group',
        callToAction: { text: 'View Group Classes', href: gcseClassesUrl },
      },
      {
        title: '1-to-1 Tuition',
        description:
          'Personalised GCSE, IGCSE, KS3, Functional Skills or A-Level support focused on the student’s gaps and goals.',
        icon: 'tabler:user-check',
        callToAction: { text: 'Ask About Tuition', href: consultationBookingUrl },
      },
      {
        title: 'Online Courses',
        description: 'Online Maths tuition and course options for families who want structured support from home.',
        icon: 'tabler:device-laptop',
        callToAction: { text: 'View Online Options', href: onlineTuitionUrl },
      },
      {
        title: 'Coding & Problem-Solving',
        description:
          'Beginner coding support for students who want to build logic, confidence and problem-solving skills.',
        icon: 'tabler:code',
        callToAction: { text: 'View Coding Course', href: codingCourseUrl },
      },
    ]}
  />

  <Features
    id="why-parents-choose"
    tagline="Why Parents Choose MathsTutorHelp"
    title="Trusted, Structured Support"
    columns={3}
    classes={compactSection}
    items={[
      {
        title: 'Qualified teacher',
        icon: 'tabler:certificate',
      },
      {
        title: 'DBS checked',
        icon: 'tabler:shield-check',
      },
      {
        title: "15+ years' experience",
        icon: 'tabler:award',
      },
      {
        title: 'Small group classes',
        icon: 'tabler:users-group',
      },
      {
        title: 'Exam-focused lessons',
        icon: 'tabler:file-check',
      },
      {
        title: 'Clear progress support',
        icon: 'tabler:list-check',
      },
    ]}
  />

  <section id="now-enrolling" class="bg-white py-8 dark:bg-slate-900 md:py-10 lg:py-12">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div
        class="grid gap-6 rounded-lg border border-primary/20 bg-brand-soft p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800 md:grid-cols-[1fr_auto] md:items-center md:p-8"
      >
        <div>
          <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Upcoming Classes</p>
          <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white">
            GCSE Classes Starting September 2026
          </h2>
          <p class="mt-3 max-w-3xl text-base leading-7 text-muted dark:text-slate-300">
            Small GCSE Foundation and Higher classes begin on Sunday 13 September 2026 at Levenshulme High School.
          </p>
          <div class="mt-4 flex flex-wrap gap-2 text-sm font-bold text-gray-800 dark:text-slate-200">
            <span class="rounded-full bg-white px-3 py-1 dark:bg-slate-900">Foundation: 10:00–11:00 am</span>
            <span class="rounded-full bg-white px-3 py-1 dark:bg-slate-900">Higher: 11:00 am–12:00 pm</span>
            <span class="rounded-full bg-white px-3 py-1 dark:bg-slate-900">Maximum seven students per class</span>
          </div>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row md:flex-col">
          <a class="btn-primary justify-center" href={groupClassInterestUrl}>Register Interest</a>
          <a class="btn-secondary justify-center" href={gcseClassesUrl}>View Group Classes</a>
        </div>
      </div>
    </div>
  </section>

  <section id="prices" class="bg-brand-soft py-8 dark:bg-slate-900 md:py-10 lg:py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Prices</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white md:text-4xl">
          Key Tuition Fees
        </h2>
        <p class="mt-3 text-base leading-7 text-muted dark:text-slate-300">
          A quick guide to the main fees. Full details are on the pricing page.
        </p>
      </div>

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {
          priceOptions.map((option) => (
            <article
              class={`relative rounded-lg border bg-white p-6 shadow-sm dark:bg-slate-800 ${
                option.featured
                  ? 'border-primary ring-2 ring-primary/20 dark:border-teal-300'
                  : 'border-gray-200 dark:border-gray-700'
              }`}
            >
              {option.featured && (
                <span class="absolute right-4 top-4 rounded-full bg-primary px-3 py-1 text-xs font-bold text-white">
                  Popular
                </span>
              )}
              <h3 class="pr-20 text-xl font-bold text-gray-950 dark:text-white">{option.label}</h3>
              <div class="mt-5 rounded-lg bg-brand-soft p-5 dark:bg-slate-900">
                <p class="flex items-end gap-2 text-primary">
                  <span class="text-5xl font-extrabold tracking-tight">{option.price}</span>
                  <span class="pb-2 text-sm font-bold text-gray-700 dark:text-slate-200">{option.unit}</span>
                </p>
              </div>
              <p class="mt-5 text-base leading-7 text-muted dark:text-slate-300">{option.description}</p>
              <a class="btn-secondary mt-5 w-full justify-center" href={option.href}>
                {option.action}
              </a>
            </article>
          ))
        }
      </div>
      <div class="mt-6 text-center">
        <a class="btn-secondary justify-center" href={pricingUrl}>View Full Pricing</a>
      </div>
    </div>
  </section>

  <Testimonials
    tagline="Parent Feedback"
    title="What Families Say"
    subtitle="Short reflections from parents and students who value calm, structured maths support."
    classes={{ container: 'py-8 md:py-10 lg:py-12' }}
    testimonials={[
      {
        title: 'Clear and patient',
        testimonial:
          'Mr Sheraz explains topics clearly and gives my child the confidence to try exam questions independently.',
        name: 'GCSE parent',
        job: 'Manchester',
      },
      {
        title: 'Confidence improved',
        testimonial:
          'The lessons are structured and calm. We can see better confidence and stronger exam technique each week.',
        name: 'Year 11 parent',
        job: 'Levenshulme',
      },
      {
        title: 'Helpful exam practice',
        testimonial:
          'I understand the methods much better now, especially when working through past-paper questions step by step.',
        name: 'A-Level student',
        job: 'Online tuition',
      },
    ]}
  />

  <CallToAction
    classes={compactSection}
    actions={[
      {
        variant: 'primary',
        text: 'Register Interest',
        href: groupClassInterestUrl,
        icon: 'tabler:calendar-check',
      },
      { text: ctaLabels.freeConsultation, href: consultationBookingUrl },
    ]}
  >
    <Fragment slot="title">Ready to Find the Right Maths Support?</Fragment>

    <Fragment slot="subtitle">
      Tell us the student level and target grade. We will help you choose the best option.
    </Fragment>
  </CallToAction>
</Layout>
