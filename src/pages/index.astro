---
import Layout from '~/layouts/PageLayout.astro';

import HomeHero from '~/components/widgets/HomeHero.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Content from '~/components/widgets/Content.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Maths Tuition in Manchester & Online',
  description:
    'GCSE, IGCSE, KS3, Functional Skills and A-Level maths support in Manchester and online from a qualified, DBS-checked teacher.',
  ignoreTitleTemplate: true,
};

const consultationBookingUrl = 'https://calendar.app.google/VJ6tgEKfsUZAncDe9';
const groupClassInterestUrl = 'https://hai-bl.com/onboarding/interest-form';
const foundationClassUrl = getPermalink('/gcse-foundation-maths-tutoring-club-2025');
const higherClassUrl = getPermalink('/gcse-revision-class-higher-manchester');
const onlineTuitionUrl = getPermalink('/online-tuition');
const summerCodingUrl = getPermalink('/manchestersummercodingclub');
const compactSection = { container: 'py-8 md:py-10 lg:py-12' };

const priceOptions = [
  {
    label: 'One-to-one tuition',
    price: '£30',
    unit: '/hr',
    description:
      'Personalised GCSE, IGCSE, A-Level or Functional Skills support. Best for targeted help and faster feedback.',
    action: 'Ask About 1:1 Tuition',
    href: consultationBookingUrl,
  },
  {
    label: 'Small group classes',
    price: '£20',
    unit: 'per session',
    description:
      'Structured Manchester-based group lessons for students who like learning with others and regular practice.',
    action: 'Register Your Interest',
    href: groupClassInterestUrl,
    featured: true,
  },
  {
    label: 'Online lessons',
    price: '£25',
    unit: '/hr',
    description:
      'Flexible online maths tuition with the same clear teaching, guided examples and exam question practice.',
    action: 'Ask About Online Lessons',
    href: consultationBookingUrl,
  },
];
---

<Layout metadata={metadata}>
  <HomeHero groupClassInterestUrl={groupClassInterestUrl} />

  <Features2
    id="meet-your-tutor"
    tagline="Meet Your Tutor"
    title="Qualified Maths Support From Mr Sheraz Cheema"
    subtitle="My name is Mr Sheraz, a fully qualified and DBS-checked maths tutor with over 15 years of teaching experience. I founded MathsTutorHelp to give students clear, structured and supportive maths tuition that builds confidence, strengthens understanding and improves exam technique. Based in Levenshulme, supporting students from Manchester, Stockport, Didsbury, Longsight, Burnage and nearby areas."
    columns={3}
    classes={compactSection}
    items={[
      {
        title: 'Clear teaching',
        description: 'Methods are explained step by step so students can follow the process and remember it later.',
        icon: 'tabler:chalkboard',
      },
      {
        title: 'Patient support',
        description: 'Students can ask questions, revisit difficult topics and build confidence at a steady pace.',
        icon: 'tabler:mood-smile',
      },
      {
        title: 'Practical next steps',
        description: 'Support is tailored to each student’s level, goals and areas of difficulty.',
        icon: 'tabler:list-check',
      },
    ]}
  />

  <Content
    id="group-classes"
    tagline="GCSE Group Classes"
    title="Small GCSE Group Maths Classes in Levenshulme"
    classes={compactSection}
    items={[
      {
        title: 'GCSE Higher Maths Classes',
        description:
          'Best for students aiming for grades 6-9, with topic revision, exam technique and guided practice.',
        icon: 'tabler:chart-line',
        callToAction: {
          text: 'View Higher Class',
          href: higherClassUrl,
        },
      },
      {
        title: 'GCSE Foundation Tutoring',
        description:
          'Best for students aiming to secure grades 4-5 with clear methods and confidence-building practice.',
        icon: 'tabler:certificate',
        callToAction: {
          text: 'View Foundation Class',
          href: foundationClassUrl,
        },
      },
      {
        title: '£20 group sessions',
        description: 'An affordable route for regular GCSE maths support, revision and exam-style practice.',
        icon: 'tabler:coin-pound',
      },
      {
        title: 'Limited places',
        description: 'Register your interest to ask about current availability or join the waiting list.',
        icon: 'tabler:users-group',
      },
    ]}
  >
    <Fragment slot="image">
      <div class="space-y-4">
        <img
          class="mx-auto w-full rounded-lg bg-gray-500 shadow-lg"
          src="https://images.unsplash.com/photo-1577896851231-70ef18881754?auto=format&fit=crop&w=1400&q=80"
          alt="Students learning together in a classroom"
          width="500"
          height="500"
          loading="lazy"
        />
        <div
          class="rounded-lg border border-gray-200 bg-white p-5 text-center shadow-sm dark:border-gray-700 dark:bg-slate-800"
        >
          <p class="text-lg font-bold text-gray-900 dark:text-white">Interested in GCSE group classes?</p>
          <p class="mt-2 text-sm text-muted dark:text-slate-300">
            Places are limited and allocated on a first-come, first-served basis.
          </p>
          <a class="btn-primary mt-4 w-full sm:w-auto" href={groupClassInterestUrl}>Register Your Interest</a>
        </div>
      </div>
    </Fragment>

    <Fragment slot="content">
      <p>
        Now enrolling for small GCSE maths group classes in Levenshulme, Manchester. Group classes are a strong option
        for students who need routine, motivation and exam-focused practice without the cost of full one-to-one tuition.
        Sessions are led personally by Mr Sheraz in a calm, supportive setting.
      </p>
    </Fragment>
  </Content>

  <Features
    id="tuition-options"
    tagline="Tuition Services"
    title="Tuition for the Stage Your Child Is At"
    subtitle="Support is available for school students, exam candidates and learners who need practical maths confidence."
    columns={4}
    classes={compactSection}
    items={[
      {
        title: 'GCSE Maths Support',
        description:
          'Foundation and Higher tier GCSE maths with exam-style practice. Supports Edexcel, AQA and OCR.',
        icon: 'tabler:math-function',
      },
      {
        title: 'IGCSE Maths Tuition',
        description:
          'Structured IGCSE help with key topics and exam technique. Pearson Edexcel and Cambridge where suitable.',
        icon: 'tabler:calculator',
      },
      {
        title: 'A-Level Maths Tuition',
        description: 'Focused help with pure maths, mechanics, statistics and problem solving.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'Online and Functional Skills',
        description: 'Flexible online lessons and practical Functional Skills maths support.',
        icon: 'tabler:video',
        callToAction: { text: 'View Online Tuition', href: onlineTuitionUrl },
      },
    ]}
  />

  <section id="prices" class="bg-brand-soft py-8 dark:bg-slate-900 md:py-10 lg:py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Prices</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white md:text-4xl">
          Simple Tuition Options
        </h2>
        <p class="mt-4 text-lg leading-8 text-muted dark:text-slate-300">
          Choose the lesson format that best fits your child, timetable and goals.
        </p>
      </div>

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {
          priceOptions.map((option) => (
            <article
              class={`relative rounded-lg border bg-white p-6 shadow-sm dark:bg-slate-800 ${
                option.featured
                  ? 'border-primary ring-2 ring-primary/20 dark:border-teal-300'
                  : 'border-gray-200 dark:border-gray-700'
              }`}
            >
              {option.featured && (
                <span class="absolute right-4 top-4 rounded-full bg-primary px-3 py-1 text-xs font-bold text-white">
                  Popular
                </span>
              )}
              <h3 class="pr-20 text-xl font-bold text-gray-950 dark:text-white">{option.label}</h3>
              <div class="mt-5 rounded-lg bg-brand-soft p-5 dark:bg-slate-900">
                <p class="flex items-end gap-2 text-primary">
                  <span class="text-5xl font-extrabold tracking-tight">{option.price}</span>
                  <span class="pb-2 text-sm font-bold text-gray-700 dark:text-slate-200">{option.unit}</span>
                </p>
              </div>
              <p class="mt-5 min-h-20 text-sm leading-6 text-muted dark:text-slate-300">{option.description}</p>
              <a class="btn-secondary mt-5 w-full justify-center" href={option.href}>{option.action}</a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <Testimonials
    tagline="Testimonials"
    title="What Parents and Students Say"
    subtitle="Real feedback from families and learners supported by MathsTutorHelp."
    classes={compactSection}
    testimonials={[
      {
        testimonial:
          'Mr Sheraz has really helped my son become more confident in Maths. The lessons are clear, structured, and focused on exam-style questions.',
        name: 'Aisha Khan',
        job: 'Parent',
        image:
          '<div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">AK</div>',
      },
      {
        testimonial:
          'The tuition helped me understand topics I used to struggle with. I like how the lessons are easy to follow and not rushed.',
        name: 'Imran Patel',
        job: 'GCSE Student',
        image:
          '<div class="flex h-10 w-10 items-center justify-center rounded-full bg-secondary text-sm font-bold text-white">IP</div>',
      },
      {
        testimonial:
          'My daughter has improved a lot since joining the sessions. The small group size means she gets support when she needs it.',
        name: 'Sadia Ahmed',
        job: 'Parent',
        image:
          '<div class="flex h-10 w-10 items-center justify-center rounded-full bg-accent text-sm font-bold text-brand-navy">SA</div>',
      },
    ]}
  />

  <section class="bg-brand-soft py-8 dark:bg-slate-900">
    <div class="mx-auto flex max-w-6xl flex-col gap-5 px-4 sm:px-6 md:flex-row md:items-center md:justify-between">
      <div>
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Also Available</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950 dark:text-white">Summer Coding Club</h2>
        <p class="mt-2 max-w-3xl text-base leading-7 text-muted dark:text-slate-300">
          A smaller extra option for students aged 13-17 who want to learn Python and develop problem-solving skills.
        </p>
      </div>
      <a class="btn-secondary shrink-0" href={summerCodingUrl}>View Summer Coding Course</a>
    </div>
  </section>

  <FAQs
    title="Frequently Asked Questions"
    subtitle="Quick answers for parents comparing maths tuition options."
    tagline="FAQs"
    columns={2}
    classes={{ container: 'max-w-6xl py-8 md:py-10 lg:py-12' }}
    items={[
      {
        title: 'Do you teach online or in person?',
        description:
          'Both options are available. In-person tuition is Manchester-based, and online lessons are available for students outside the local area.',
      },
      {
        title: 'Which levels do you teach?',
        description:
          'Tuition is available for KS3, GCSE, IGCSE, A-Level and Functional Skills maths, including exam preparation and topic support.',
      },
      {
        title: 'How do I book?',
        description:
          'Register your interest for group class places or request a free consultation. You can explain the student level, goals and preferred lesson format.',
      },
      {
        title: 'How much are group classes?',
        description: 'Group sessions are £20. Online tutoring is £25/hr and in-person one-to-one tutoring is £30/hr.',
      },
    ]}
  />

  <CallToAction
    classes={compactSection}
    actions={[
      {
        variant: 'primary',
        text: 'Register Your Interest',
        href: groupClassInterestUrl,
        icon: 'tabler:calendar-check',
      },
      { text: 'Book a Free Consultation', href: consultationBookingUrl },
    ]}
  >
    <Fragment slot="title">Ready to Find the Right Maths Support?</Fragment>

    <Fragment slot="subtitle">
      Tell us the student level, target grade and the areas that feel difficult. We will help you choose between
      one-to-one tuition, online lessons or a GCSE group class.
    </Fragment>
  </CallToAction>
</Layout>
