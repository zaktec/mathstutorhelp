---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { Icon } from 'astro-icon/components';
import { getAsset, getPermalink } from '~/utils/permalinks';
import { bookingLinks, contactDetails, ctaLabels } from '~/utils/siteDetails';

const metadata = {
  title: 'Maths Tuition Manchester | 1-to-1, Online & GCSE Classes',
  description:
    'Maths tuition in Manchester for KS3, GCSE, IGCSE, Functional Skills and A-Level, with 1-to-1 lessons, online tuition and GCSE group classes.',
};

const consultationBookingUrl = bookingLinks.freeConsultation;
const contactUrl = getPermalink('/contact');
const onlineTuitionUrl = getPermalink('/online-tuition');
const gcseClassesUrl = getPermalink('/gcse-classes');
const pricingUrl = getPermalink('/pricing');

const tuitionCards = [
  {
    title: 'Online Tuition',
    icon: 'tabler:device-laptop',
    description: 'Live one-to-one maths tuition from home.',
    bestFor: 'Students who need regular support without travel.',
    action: 'View Online Tuition',
    href: onlineTuitionUrl,
  },
  {
    title: 'In-Person Tuition',
    icon: 'tabler:user-check',
    description: 'Manchester-based face-to-face maths tuition.',
    bestFor: 'Students who prefer learning in person.',
    action: ctaLabels.freeConsultation,
    href: consultationBookingUrl,
    featured: true,
  },
  {
    title: 'GCSE Group Classes',
    icon: 'tabler:users-group',
    description: 'Small Foundation and Higher GCSE groups.',
    bestFor: 'Students who need routine and motivation.',
    action: 'View GCSE Classes',
    href: gcseClassesUrl,
  },
  {
    title: 'A-Level Tuition',
    icon: 'tabler:chart-line',
    description:
      'Pure maths, statistics, mechanics and exam questions. One-to-one A-Level tuition follows the standard rates: £25/hr online or £30/hr in person.',
    bestFor: 'Year 12 and Year 13 students.',
    action: 'Ask About A-Level',
    href: consultationBookingUrl,
  },
];
---

<Layout metadata={metadata}>
  <Hero
    tagline="Maths Tuition Services"
    title="Maths Tuition in Manchester and Online"
    subtitle="Structured maths support for KS3, GCSE, IGCSE, Functional Skills and A-Level students, taught by a qualified, DBS-checked teacher."
    actions={[
      {
        variant: 'primary',
        text: ctaLabels.freeConsultation,
        href: consultationBookingUrl,
        icon: 'tabler:calendar-check',
      },
      { text: 'View Full Pricing', href: pricingUrl },
    ]}
    image={{
      src: getAsset('/images/maths-tuition-courses.jpg'),
      alt: 'Online, group and revision maths courses',
    }}
  />

  <section class="bg-white py-12 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Tuition Options</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white md:text-4xl">
          Choose the Right Maths Tuition
        </h2>
        <p class="mt-4 text-lg leading-8 text-muted dark:text-slate-300">
          Compare the main support routes at a glance.
        </p>
      </div>

      <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        {
          tuitionCards.map((option) => (
            <article
              class={`flex h-full flex-col rounded-lg border bg-white p-6 shadow-sm dark:bg-slate-800 ${
                option.featured
                  ? 'border-primary ring-2 ring-primary/20 dark:border-teal-300'
                  : 'border-gray-200 dark:border-gray-700'
              }`}
            >
              <div class="flex items-start justify-between gap-4">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-md bg-brand-soft text-primary dark:bg-slate-900 dark:text-teal-200">
                  <Icon name={option.icon} class="h-6 w-6" />
                </div>
                {option.featured && (
                  <span class="rounded-full bg-primary px-3 py-1 text-xs font-bold text-white">Popular</span>
                )}
              </div>
              <h3 class="mt-5 text-xl font-bold text-gray-950 dark:text-white">{option.title}</h3>
              <p class="mt-4 text-sm leading-6 text-muted dark:text-slate-300">{option.description}</p>
              <p class="mt-4 rounded-md bg-brand-soft p-3 text-sm font-semibold leading-6 text-gray-800 dark:bg-slate-900 dark:text-slate-200">
                Best for: {option.bestFor}
              </p>
              <div class="mt-auto pt-5">
                <a class="btn-secondary w-full justify-center" href={option.href}>
                  {option.action}
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <Features
    title="Support for the Stage Your Child Is At"
    subtitle="Choose support by level, exam route or learning goal."
    columns={5}
    items={[
      {
        title: 'KS3 Maths',
        description: 'Years 7-9 foundations before GCSE.',
        icon: 'tabler:school',
      },
      {
        title: 'GCSE Maths',
        description: 'Foundation and Higher support.',
        icon: 'tabler:certificate',
      },
      {
        title: 'IGCSE Maths',
        description: 'Pearson Edexcel and Cambridge routes where suitable.',
        icon: 'tabler:calculator',
      },
      {
        title: 'Functional Skills',
        description: 'Level 1 and Level 2 practical maths.',
        icon: 'tabler:list-check',
      },
      {
        title: 'A-Level Maths',
        description: 'Pure maths, statistics and mechanics.',
        icon: 'tabler:function',
      },
    ]}
  />

  <Content
    isReversed
    title="Online Learning Platform Included"
    items={[
      {
        title: 'Topic resources and worksheets',
        description: 'Resources matched to the student’s level.',
      },
      {
        title: 'Practice tasks',
        description: 'Short tasks to keep learning moving between lessons.',
      },
      {
        title: 'Video explanations',
        description: 'Helpful methods students can revisit.',
      },
      {
        title: 'Revision support',
        description: 'Extra practice for homework, mocks and exams.',
      },
    ]}
    image={{
      src: getAsset('/images/online-maths-lesson-laptop.jpg'),
      alt: 'Student using an online learning platform',
    }}
  >
    <Fragment slot="content">
      <p>
        Students can receive resources alongside live tutoring, so practice continues between lessons without adding
        extra pressure.
      </p>
    </Fragment>
  </Content>

  <FAQs
    title="Maths Tuition FAQs"
    columns={2}
    items={[
      {
        title: 'Which levels do you support?',
        description: 'Tuition is available for KS3, GCSE, IGCSE, Functional Skills and A-Level maths.',
      },
      {
        title: 'Is tuition available online and in person?',
        description: 'Yes. Online lessons are available UK-wide, and in-person tuition is available in Manchester.',
      },
      {
        title: 'Is access to the online learning platform included?',
        description:
          'Yes. Students can use online resources, worksheets, practice questions, video explanations and revision tasks between lessons.',
      },
      {
        title: 'How do we book a lesson?',
        description: `Book a free consultation or message MathsTutorHelp on WhatsApp at ${contactDetails.phoneCompact} to ask about availability.`,
      },
    ]}
  />

  <CallToAction
    title="Ready to Find the Right Tuition Option?"
    subtitle="Book a free consultation and I will help you choose the best support for your child."
    actions={[
      {
        variant: 'primary',
        text: ctaLabels.freeConsultation,
        href: consultationBookingUrl,
        icon: 'tabler:calendar-check',
      },
      { text: 'Contact MathsTutorHelp', href: contactUrl, icon: 'tabler:send' },
    ]}
  />
</Layout>
