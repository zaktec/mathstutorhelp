---
import Layout from '~/layouts/PageLayout.astro';
import BlogCard from '~/components/blog/BlogCard.astro';
import { blogPosts, getBlogTags } from '~/utils/blogPosts';

export function getStaticPaths() {
  return getBlogTags().map((tag) => ({
    params: { tag: tag.toLowerCase().replaceAll(' ', '-') },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const posts = blogPosts.filter((post) => post.tags.includes(tag));
const metadata = {
  title: `${tag} Articles`,
  description: `MathsTutorHelp articles about ${tag.toLowerCase()}.`,
  robots: {
    index: false,
    follow: true,
  },
};
---

<Layout metadata={metadata}>
  <section class="bg-brand-soft py-12 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <p class="text-sm font-bold uppercase text-secondary dark:text-teal-200">Blog topic</p>
      <h1 class="mt-2 text-4xl font-bold text-gray-950 dark:text-white">{tag}</h1>
    </div>
  </section>
  <section class="bg-white py-12 dark:bg-slate-900">
    <div class="mx-auto grid max-w-7xl gap-5 px-4 sm:px-6 md:grid-cols-2 xl:grid-cols-3">
      {posts.map((post) => <BlogCard post={post} />)}
    </div>
  </section>
</Layout>
