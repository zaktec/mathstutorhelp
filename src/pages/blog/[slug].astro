---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getAsset, getPermalink } from '~/utils/permalinks';
import { blogPosts } from '~/utils/blogPosts';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

const metadata = {
  title: `${post.title} | MathsTutorHelp Blog`,
  description: post.excerpt,
};
---

<Layout metadata={metadata}>
  <article class="bg-white py-12 dark:bg-slate-900 md:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <a class="text-sm font-bold text-primary underline-offset-4 hover:underline" href={getPermalink('/blog')}>
        Back to Blog
      </a>
      <p class="mt-6 text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">{post.category}</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-gray-950 dark:text-white md:text-5xl">{post.title}</h1>
      <p class="mt-4 text-sm text-muted dark:text-slate-400">
        {new Date(post.date).toLocaleDateString('en-GB', {
          day: 'numeric',
          month: 'long',
          year: 'numeric',
        })}
      </p>
      <img
        class="mt-8 w-full rounded-lg border border-gray-200 object-cover shadow-sm dark:border-gray-700"
        src={getAsset(post.image)}
        alt={post.imageAlt}
        width="900"
        height="298"
      />
      <p class="mt-6 text-xl leading-8 text-muted dark:text-slate-300">{post.excerpt}</p>

      <div class="mt-10 space-y-10">
        {
          post.content.map((section) => (
            <section>
              <h2 class="text-2xl font-bold text-gray-950 dark:text-white">{section.heading}</h2>
              <div class="mt-4 space-y-4 text-lg leading-8 text-muted dark:text-slate-300">
                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
            </section>
          ))
        }
      </div>
    </div>
  </article>

  <CallToAction
    title="Want Help With Maths?"
    subtitle="MathsTutorHelp offers online, in-person and small group maths support for students who need clearer methods and regular practice."
    actions={[
      {
        variant: 'primary',
        text: 'Ask About Maths Support',
        href: getPermalink('/contact'),
        icon: 'tabler:message',
      },
      {
        text: 'View Tuition Options',
        href: getPermalink('/maths-tuition'),
      },
    ]}
  />
</Layout>
