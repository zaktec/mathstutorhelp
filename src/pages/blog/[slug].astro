---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import BlogCard from '~/components/blog/BlogCard.astro';
import SocialShare from '~/components/blog/SocialShare.astro';
import Image from '~/components/common/Image.astro';
import { getAsset, getPermalink } from '~/utils/permalinks';
import { blogPosts, getRelatedPosts } from '~/utils/blogPosts';
import { getBlogImage } from '~/data/images';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const relatedPosts = getRelatedPosts(post);

const metadata = {
  title: post.title,
  description: post.excerpt,
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.excerpt,
  image: String(new URL(getAsset(post.image), Astro.site)),
  datePublished: post.date,
  dateModified: post.date,
  author: {
    '@type': 'Person',
    name: 'Mr Sheraz',
  },
  publisher: {
    '@type': 'Organization',
    name: 'MathsTutorHelp',
    logo: {
      '@type': 'ImageObject',
      url: String(new URL(getAsset('/images/maths-tutor-sheraz-cheema.jpeg'), Astro.site)),
    },
  },
  mainEntityOfPage: String(Astro.url),
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <article class="bg-white py-12 dark:bg-slate-900 md:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <a
        class="inline-flex min-h-11 items-center py-2 text-sm font-bold text-primary underline-offset-4 hover:underline"
        href={getPermalink('/blog')}
      >
        Back to Blog
      </a>
      <p class="mt-6 text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">{post.category}</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-gray-950 dark:text-white md:text-5xl">{post.title}</h1>
      <p class="mt-4 text-sm text-muted dark:text-slate-400">
        {
          new Date(post.date).toLocaleDateString('en-GB', {
            day: 'numeric',
            month: 'long',
            year: 'numeric',
          })
        }
      </p>
      <Image
        class="mt-8 w-full rounded-lg border border-gray-200 object-cover shadow-sm dark:border-gray-700"
        src={getBlogImage(post.image)}
        alt={post.imageAlt}
        widths={[400, 640, 900]}
        sizes="(max-width: 767px) 100vw, 768px"
        width={900}
        height={298}
        layout="responsive"
        format="webp"
      />
      <p class="mt-6 text-xl leading-8 text-muted dark:text-slate-300">{post.excerpt}</p>

      <div class="mt-5 flex flex-wrap gap-2">
        {
          post.tags.map((tag) => (
            <a
              class="inline-flex min-h-11 items-center rounded-md bg-brand-soft px-3 py-2 text-sm font-semibold text-primary dark:bg-slate-800"
              href={getPermalink(`/blog/tag/${tag.toLowerCase().replaceAll(' ', '-')}`)}
            >
              {tag}
            </a>
          ))
        }
      </div>

      <div class="mt-10 space-y-10">
        {
          post.content.map((section) => (
            <section>
              <h2 class="text-2xl font-bold text-gray-950 dark:text-white">{section.heading}</h2>
              <div class="mt-4 space-y-4 text-lg leading-8 text-muted dark:text-slate-300">
                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
            </section>
          ))
        }
      </div>
      <SocialShare title={post.title} url={Astro.url} />
    </div>
  </article>

  <section class="bg-gray-50 py-12 dark:bg-slate-950" aria-labelledby="related-posts-title">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <h2 id="related-posts-title" class="text-3xl font-bold text-gray-950 dark:text-white">Related articles</h2>
      <div class="mt-6 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {relatedPosts.map((relatedPost) => <BlogCard post={relatedPost} />)}
      </div>
    </div>
  </section>

  <CallToAction
    title="Want Help With Maths?"
    subtitle="MathsTutorHelp offers online, in-person and small group maths support for students who need clearer methods and regular practice."
    actions={[
      {
        variant: 'primary',
        text: 'Ask About Maths Support',
        href: getPermalink('/contact'),
        icon: 'tabler:message',
      },
      {
        text: 'View Tuition Options',
        href: getPermalink('/maths-tuition'),
      },
    ]}
  />
</Layout>
