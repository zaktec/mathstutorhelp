---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import BlogCard from '~/components/blog/BlogCard.astro';
import Pagination from '~/components/blog/Pagination.astro';
import { getAsset, getPermalink } from '~/utils/permalinks';
import { BLOG_POSTS_PER_PAGE, blogPosts, getBlogTags } from '~/utils/blogPosts';

const posts = blogPosts.slice(0, BLOG_POSTS_PER_PAGE);
const totalPages = Math.ceil(blogPosts.length / BLOG_POSTS_PER_PAGE);
const tags = getBlogTags();

const metadata = {
  title: 'Maths Blog',
  description:
    'MathsTutorHelp blog with GCSE Maths revision advice, online tuition guidance and parent-friendly maths support tips.',
};
---

<Layout metadata={metadata}>
  <section class="bg-brand-soft py-12 dark:bg-slate-900 md:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">MathsTutorHelp Blog</p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight text-gray-950 dark:text-white md:text-5xl">
        Maths Revision and Tuition Advice
      </h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-muted dark:text-slate-300">
        Helpful articles for parents and students covering GCSE Maths revision, finding the right tutor, online tuition
        and building maths confidence.
      </p>
      <div class="mt-6 flex flex-wrap items-center gap-3">
        {
          tags.map((tag) => (
            <a
              class="inline-flex min-h-11 items-center rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-semibold text-gray-800 hover:border-primary hover:text-primary dark:border-gray-600 dark:bg-slate-800 dark:text-gray-100"
              href={getPermalink(`/blog/tag/${tag.toLowerCase().replaceAll(' ', '-')}`)}
            >
              {tag}
            </a>
          ))
        }
        <a
          class="inline-flex min-h-11 items-center py-2 text-sm font-bold text-primary underline-offset-4 hover:underline"
          href={getAsset('/rss.xml')}
        >
          RSS feed
        </a>
      </div>
    </div>
  </section>

  <section class="bg-white py-12 dark:bg-slate-900">
    <div class="mx-auto grid max-w-7xl gap-5 px-4 sm:px-6 md:grid-cols-2 xl:grid-cols-3">
      {posts.map((post) => <BlogCard post={post} />)}
    </div>
    <Pagination currentPage={1} totalPages={totalPages} />
  </section>

  <CallToAction
    title="Need Maths Support?"
    subtitle="If an article raises a question about your child’s maths, get in touch and I will help you choose the right support."
    actions={[
      {
        variant: 'primary',
        text: 'Contact MathsTutorHelp',
        href: getPermalink('/contact'),
        icon: 'tabler:message',
      },
      {
        text: 'View Maths Tuition',
        href: getPermalink('/maths-tuition'),
      },
    ]}
  />
</Layout>
