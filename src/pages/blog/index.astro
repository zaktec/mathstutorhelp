---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getAsset, getPermalink } from '~/utils/permalinks';
import { blogPosts } from '~/utils/blogPosts';

const metadata = {
  title: 'Maths Blog | MathsTutorHelp',
  description:
    'MathsTutorHelp blog with GCSE Maths revision advice, online tuition guidance and parent-friendly maths support tips.',
};
---

<Layout metadata={metadata}>
  <section class="bg-brand-soft py-12 dark:bg-slate-900 md:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">MTH Blog</p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight text-gray-950 dark:text-white md:text-5xl">
        Maths Revision and Tuition Advice
      </h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-muted dark:text-slate-300">
        Helpful articles for parents and students covering GCSE Maths revision, finding the right tutor, online tuition
        and building maths confidence.
      </p>
    </div>
  </section>

  <section class="bg-white py-12 dark:bg-slate-900">
    <div class="mx-auto grid max-w-7xl gap-5 px-4 sm:px-6 md:grid-cols-2 xl:grid-cols-3">
      {
        blogPosts.map((post) => (
          <article class="flex h-full flex-col overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-slate-800">
            <a href={getPermalink(`/blog/${post.slug}`)} class="block bg-gray-100 dark:bg-slate-700">
              <img
                class="h-40 w-full object-cover"
                src={getAsset(post.image)}
                alt={post.imageAlt}
                loading="lazy"
                width="900"
                height="298"
              />
            </a>
            <div class="flex flex-1 flex-col p-6">
              <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">{post.category}</p>
              <h2 class="mt-3 text-2xl font-bold text-gray-950 dark:text-white">{post.title}</h2>
              <p class="mt-2 text-sm text-muted dark:text-slate-400">
                {new Date(post.date).toLocaleDateString('en-GB', {
                  day: 'numeric',
                  month: 'long',
                  year: 'numeric',
                })}
              </p>
              <p class="mt-4 flex-1 text-base leading-7 text-muted dark:text-slate-300">{post.excerpt}</p>
              <a class="btn-secondary mt-6 w-full justify-center sm:w-auto" href={getPermalink(`/blog/${post.slug}`)}>
                Read Article
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <CallToAction
    title="Need Maths Support?"
    subtitle="If an article raises a question about your child’s maths, get in touch and I will help you choose the right support."
    actions={[
      {
        variant: 'primary',
        text: 'Contact MathsTutorHelp',
        href: getPermalink('/contact'),
        icon: 'tabler:message',
      },
      {
        text: 'View Maths Tuition',
        href: getPermalink('/maths-tuition'),
      },
    ]}
  />
</Layout>
