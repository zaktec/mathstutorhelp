---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';
import { bookingLinks, contactDetails, ctaLabels, tuitionPrices } from '~/utils/siteDetails';
import { siteImages } from '~/data/images';

const metadata = {
  title: 'MathsTutorHelp GCSE Maths Foundation Tutoring Manchester',
  description:
    'MathsTutorHelp GCSE Foundation Maths tutoring club in Levenshulme, Manchester for Year 10 and 11 students working towards grades 4-5.',
};

const interestFormUrl = bookingLinks.groupClassInterest;
const contactUrl = getPermalink('/contact');
const higherClassUrl = getPermalink('/gcse-revision-class-higher-manchester');
const onlineTuitionUrl = getPermalink('/online-tuition');
const phoneDisplay = contactDetails.phoneDisplay;
const eventSchema = {
  '@context': 'https://schema.org',
  '@type': 'EducationEvent',
  name: 'MathsTutorHelp GCSE Maths Foundation Tutoring',
  description: metadata.description,
  url: String(Astro.url),
  startDate: '2026-09-13T10:00:00+01:00',
  endDate: '2027-05-30T11:00:00+01:00',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  eventStatus: 'https://schema.org/EventScheduled',
  location: {
    '@type': 'Place',
    name: 'Levenshulme High School',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Crossley Road',
      addressLocality: 'Levenshulme',
      addressRegion: 'Manchester',
      postalCode: 'M19 1FS',
      addressCountry: 'GB',
    },
  },
  organizer: {
    '@type': 'EducationalOrganization',
    name: 'MathsTutorHelp',
    url: String(new URL(getPermalink('/'), Astro.site)),
    telephone: contactDetails.phoneDisplay,
  },
  offers: {
    '@type': 'Offer',
    price: '20',
    priceCurrency: 'GBP',
    availability: 'https://schema.org/LimitedAvailability',
    url: interestFormUrl,
  },
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(eventSchema)} />

  <Hero
    tagline="MathsTutorHelp Group Classes"
    title="MathsTutorHelp GCSE Maths Foundation Tutoring"
    subtitle="Small group GCSE Foundation Maths classes from MathsTutorHelp in Levenshulme, helping students move from grade 3 towards grade 5 with structured weekly exam practice."
    actions={[
      {
        variant: 'primary',
        text: ctaLabels.groupClassInterest,
        href: interestFormUrl,
        target: '_blank',
        icon: 'tabler:calendar-check',
      },
      { text: 'Contact MathsTutorHelp', href: contactUrl },
    ]}
    image={{
      src: siteImages.gallery.classesPoster,
      alt: 'GCSE maths class poster for Manchester students',
    }}
  />

  <Features
    title="Foundation Class Details"
    subtitle="A calm, structured class for students who need confidence, clear methods and regular GCSE practice."
    columns={3}
    items={[
      {
        title: 'Grades 3-5 focus',
        description: 'Designed for Foundation Tier students aiming to secure grades 4-5 and strengthen core skills.',
        icon: 'tabler:certificate',
      },
      {
        title: 'Sundays 10:00am-11:00am',
        description: 'Weekly sessions from 13 September 2026 to May 2027, covering the full exam preparation period.',
        icon: 'tabler:clock',
      },
      {
        title: 'Levenshulme High School',
        description: 'In-person tutoring club at Levenshulme High School, Manchester, M19 1FS.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Maximum 7 students',
        description: 'Small groups keep lessons focused and allow students to ask questions.',
        icon: 'tabler:users-group',
      },
      {
        title: 'Simple pricing',
        description: `${tuitionPrices.smallGroup.display} pay-as-you-go, or £16 per session with advance block booking.`,
        icon: 'tabler:coin-pound',
      },
      {
        title: 'No-screen lessons',
        description: 'Paper-based practice helps students focus and prepare for real exam conditions.',
        icon: 'tabler:file-pencil',
      },
    ]}
  />

  <Content
    title="What Students Work On"
    items={[
      {
        title: 'Key Foundation topics',
        description: 'Clear teaching of number, algebra, ratio, geometry and common topics needed for grades 4-5.',
      },
      {
        title: 'Exam-style practice',
        description: 'Students practise exam-style questions every lesson and learn how to show working clearly.',
      },
      {
        title: 'Diagnostic support',
        description: 'Lessons respond to weak areas so students spend time on the topics that matter most.',
      },
      {
        title: 'Independent practice',
        description: 'Students work independently with support where needed, building confidence and resilience.',
      },
      {
        title: 'Homework and materials',
        description: 'Students can bring schoolwork, use tutor-provided worksheets or access bonus practice tasks.',
      },
    ]}
    image={{
      src: siteImages.gallery.circleTheorems,
      alt: 'GCSE Maths classroom board work',
    }}
  >
    <Fragment slot="content">
      <p>
        This class is for Year 10 and Year 11 Foundation Tier students who need structured weekly support, exam practice
        and a clear route towards grades 4-5.
      </p>
    </Fragment>
  </Content>

  <Features
    title="Booking and Attendance"
    subtitle="A calm, focused Foundation class with flexible attendance once your child’s place is reserved."
    columns={3}
    items={[
      {
        title: 'Reserve a place first',
        description: 'Places are limited because the group is capped at 7 students.',
        icon: 'tabler:calendar-check',
      },
      {
        title: 'Pay flexibly',
        description: 'Students can pay on the day once their place is reserved, or ask about block booking.',
        icon: 'tabler:coin-pound',
      },
      {
        title: 'No joining fee',
        description: 'Flexible pay-as-you-go access is available where spaces remain.',
        icon: 'tabler:circle-check',
      },
      {
        title: 'Exam board support',
        description: 'AQA, Edexcel and OCR tasks can be adapted to the student’s specification.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Paper-based lessons',
        description: 'No screens in class, just structured study and exam-style written practice.',
        icon: 'tabler:file-pencil',
      },
      {
        title: 'Parent updates',
        description: 'Progress updates can be shared by WhatsApp on request.',
        icon: 'tabler:message-circle',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-brand-soft dark:bg-transparent"></div>
    </Fragment>
  </Features>

  <FAQs
    title="Foundation Class FAQs"
    columns={2}
    items={[
      {
        title: 'What if my child misses a session?',
        description: 'Let us know in advance. Where possible, your child can attend the next suitable session.',
      },
      {
        title: 'Can my child bring schoolwork?',
        description: 'Yes. Students can bring schoolwork or use tutor-provided worksheets and practice questions.',
      },
      {
        title: 'How is progress tracked?',
        description: 'Progress is tracked through diagnostic tasks, mock-style practice and tutor feedback.',
      },
      {
        title: 'Which exam boards are covered?',
        description: 'AQA, Edexcel and OCR can be supported, with tasks adapted to the student specification.',
      },
      {
        title: 'Do students use computers in class?',
        description: 'No. Work is paper-based to reflect real exam conditions and reduce distractions.',
      },
      {
        title: 'Can my child join mid-way through the term?',
        description:
          'Yes. Students can join mid-way if a place is available. The first session includes a diagnostic check.',
      },
      {
        title: 'Do you run sessions during school holidays?',
        description: 'Holiday class dates are shared by WhatsApp when available.',
      },
      {
        title: 'Can parents get feedback?',
        description: 'Yes. Updates can be shared by WhatsApp on request.',
      },
      {
        title: 'Is there a free trial?',
        description: 'Ask about current trial or first-session arrangements when you register interest.',
      },
      {
        title: 'Who teaches the class?',
        description:
          'The class is taught by Mr Sheraz, a qualified and DBS-checked maths teacher with 15+ years of teaching experience.',
      },
      {
        title: 'Is this suitable for Higher Tier students?',
        description: `This class is for Foundation Tier. Higher students can view the Higher group here: <a class="underline" href="${higherClassUrl}">GCSE Higher class</a>.`,
      },
      {
        title: 'Is there an online option?',
        description: `Students who prefer learning from home can view online tuition options here: <a class="underline" href="${onlineTuitionUrl}">Online Maths Tuition</a>.`,
      },
    ]}
  />

  <CallToAction
    title="Reserve a Foundation Class Place"
    subtitle={`Spaces are limited to keep the group focused and supportive. Book early to ask about the £16 advance block booking rate, or call/WhatsApp ${phoneDisplay} if you have questions.`}
    actions={[
      {
        variant: 'primary',
        text: ctaLabels.groupClassInterest,
        href: interestFormUrl,
        target: '_blank',
        icon: 'tabler:calendar-check',
      },
      { text: 'Contact MathsTutorHelp', href: contactUrl },
    ]}
  />
</Layout>
