---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'About Maths Tutor Help — Professional Maths Tuition in Manchester & Online',
  description:
    'Maths Tutor Help provides professional maths tuition in Manchester and online for KS3, GCSE, IGCSE, Functional Skills and A-Level students.',
};

const consultationBookingUrl = 'https://calendar.app.google/VJ6tgEKfsUZAncDe9';
---

<Layout metadata={metadata}>
  <Hero
    tagline="About Maths Tutor Help"
    title="About Maths Tutor Help — Professional Maths Tuition in Manchester & Online"
    subtitle="Supporting KS3, GCSE, IGCSE, Functional Skills and A-Level students with personalised maths tuition in Manchester and online."
    actions={[
      {
        variant: 'primary',
        text: 'Book a Free Consultation',
        href: consultationBookingUrl,
        icon: 'tabler:calendar-check',
      },
      { text: 'View Tuition Options', href: getPermalink('/maths-tuition') },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1577896851231-70ef18881754?auto=format&fit=crop&w=1800&q=80',
      alt: 'Maths Tutor Help classroom support',
    }}
  />

  <Content
    title="Supporting Students With Clear, Personalised Maths Help"
    items={[
      {
        title: 'Clear explanations',
        description: 'Topics are broken down into simple steps so students understand the method, not just the answer.',
      },
      {
        title: 'Personalised lesson plans',
        description: 'Support is adapted to each learner’s goals, strengths and areas for improvement.',
      },
      {
        title: 'Progress tracking',
        description: 'Lessons focus on closing gaps, reinforcing understanding and preparing students for exams.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1596495577886-d920f1fb7238?auto=format&fit=crop&w=1400&q=80',
      alt: 'Student receiving maths tuition',
    }}
  >
    <Fragment slot="content">
      <p>
        Welcome to Maths Tutor Help (MTH), a trusted place for maths tutoring in Manchester and online, helping learners
        build confidence, strengthen understanding and achieve higher grades. We specialise in KS3, GCSE, IGCSE,
        Functional Skills Level 1-2 and A-Level Maths, offering personalised support for students of all abilities.
      </p>
      <p>
        Many students do not struggle because they lack potential. They simply have not had clear explanations,
        individual attention or the right guidance at the right time. Our mission is to provide that support through
        structured teaching, personalised lesson plans and consistent progress tracking.
      </p>
    </Fragment>
  </Content>

  <Features
    title="What Makes Us Different?"
    subtitle="With over 10 years of experience in mainstream classrooms, lessons are interactive, step-by-step and confidence-building."
    columns={3}
    items={[
      {
        title: 'Simple steps',
        description: 'We break difficult topics into manageable stages and revisit gaps until methods feel secure.',
        icon: 'tabler:list-check',
      },
      {
        title: 'Guided practice',
        description:
          'Students build confidence through examples, questions and feedback that match their current level.',
        icon: 'tabler:pencil-check',
      },
      {
        title: 'Exam preparation',
        description: 'GCSE, IGCSE and A-Level students practise exam-style questions and proven revision strategies.',
        icon: 'tabler:file-check',
      },
      {
        title: 'Problem solving',
        description: 'Lessons encourage independence, reasoning and the ability to choose the right method.',
        icon: 'tabler:bulb',
      },
      {
        title: '1:1 and group classes',
        description: 'Students can choose individual tuition or affordable, focused small group classes.',
        icon: 'tabler:users-group',
      },
      {
        title: 'Online and in person',
        description: 'Lessons are available online and in person in Manchester.',
        icon: 'tabler:device-laptop',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-brand-soft dark:bg-transparent"></div>
    </Fragment>
  </Features>

  <Features
    title="Maths Tuition Services We Offer"
    subtitle="Flexible support options for different ages, goals and learning needs."
    columns={3}
    items={[
      {
        title: 'KS3 Maths Tuition',
        description: 'Years 7-9 support for building strong foundations and early confidence.',
        icon: 'tabler:books',
      },
      {
        title: 'GCSE and IGCSE Maths',
        description: 'Foundation and Higher support for exam preparation, revision and grade improvement.',
        icon: 'tabler:certificate',
      },
      {
        title: 'Functional Skills Maths',
        description: 'Level 1 and Level 2 support for adult learners, apprentices and college students.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'A-Level Maths',
        description: 'Advanced topics including algebra, calculus, mechanics and statistics.',
        icon: 'tabler:chart-line',
      },
      {
        title: '1:1 Tuition',
        description: 'Targeted, personalised learning online or in person.',
        icon: 'tabler:user-check',
      },
      {
        title: 'Small Group Classes',
        description: 'Affordable, engaging and collaborative learning for students who benefit from group support.',
        icon: 'tabler:users',
      },
    ]}
  />

  <Content
    isReversed
    title="Why Parents Choose Us"
    items={[
      {
        title: 'Qualified teacher',
        description: 'Students are supported by an experienced maths teacher, not just a tutor.',
      },
      {
        title: 'Support for all abilities',
        description: 'From struggling learners to high achievers, lessons meet students where they are.',
      },
      {
        title: 'Revision plans and worksheets',
        description: 'Students receive structured practice and resources to support learning between sessions.',
      },
      {
        title: '1:1 and group learning options',
        description: 'Families can choose individual tuition or small group lessons depending on the student’s needs.',
      },
      {
        title: 'Online learning platform',
        description: 'Extra digital resources and learning support help students keep practising.',
      },
      {
        title: 'Visible progress tracking',
        description: 'Parents can see what is improving and what the student should focus on next.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1635070041078-e363dbe005cb?auto=format&fit=crop&w=1400&q=80',
      alt: 'Maths notes and exam practice',
    }}
  >
    <Fragment slot="content">
      <p>
        With structured teaching, expert guidance and continuous support, we help students grow step by step, at their
        pace and in their way.
      </p>
    </Fragment>
  </Content>

  <Content
    title="Meet the Founder: Mr Sheraz"
    items={[
      {
        title: 'Founder and Lead Tutor',
        description:
          'Maths Tutor Help was founded by Mr Sheraz, a qualified and DBS-checked maths teacher in Manchester.',
      },
      {
        title: "15+ years' experience",
        description: 'Experience across UK schools, colleges, international institutions and private tuition.',
      },
      {
        title: 'Specialist maths support',
        description: 'Specialist in KS3, GCSE, IGCSE, Functional Skills and A-Level Maths.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=1400&q=80',
      alt: 'Tutor supporting students',
    }}
  >
    <Fragment slot="content">
      <p>
        Mr Sheraz established MTH after seeing first-hand how many students fall behind due to lack of personalised
        support, fast-paced classrooms and missing foundational understanding.
      </p>
      <blockquote class="mt-6 border-l-4 border-primary pl-4 text-xl font-medium text-gray-900 dark:text-white">
        Every learner can succeed in Maths with the right structure, guidance and encouragement. My goal is not only to
        raise grades, but to help students enjoy learning and believe in themselves.
      </blockquote>
    </Fragment>
  </Content>

  <CallToAction
    title="Ready to Talk About Maths Support?"
    subtitle="Tell us the student's level, goals and preferred lesson format. We will help you choose the right next step."
    actions={[
      {
        variant: 'primary',
        text: 'Book a Free Consultation',
        href: consultationBookingUrl,
        icon: 'tabler:calendar-check',
      },
      { text: 'View Group Classes', href: getPermalink('/gcse-revision-class-higher-manchester') },
    ]}
  />
</Layout>
