---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';
import { bookingLinks, ctaLabels } from '~/utils/siteDetails';
import { siteImages } from '~/data/images';

const metadata = {
  title: 'About Mr Sheraz',
  description:
    'Learn about MathsTutorHelp and Mr Sheraz, a qualified and DBS-checked maths teacher providing GCSE, IGCSE, Functional Skills, A-Level maths tuition and beginner coding support in Manchester and online.',
};

const consultationBookingUrl = bookingLinks.freeConsultation;
const tuitionUrl = getPermalink('/maths-tuition');
const groupClassesUrl = getPermalink('/gcse-revision-class-higher-manchester');
const tutorImageUrl = siteImages.tutor;
---

<Layout metadata={metadata}>
  <Hero
    tagline="About MathsTutorHelp"
    title="About Mr Sheraz and MathsTutorHelp"
    subtitle="Qualified, DBS-checked maths and coding support for students in Manchester and online, with lessons built around clear explanations, confidence and steady progress."
    actions={[
      {
        variant: 'primary',
        text: ctaLabels.freeConsultation,
        href: consultationBookingUrl,
        icon: 'tabler:calendar-check',
      },
      { text: 'View Tuition Options', href: tuitionUrl },
    ]}
  />

  <Content
    title="Meet Mr Sheraz at MathsTutorHelp"
    items={[
      {
        title: 'Qualified teacher',
        description:
          'A fully qualified maths teacher with classroom, private tuition and computer science teaching experience.',
      },
      {
        title: 'DBS checked',
        description: 'Professional, responsible support for students and families.',
      },
      {
        title: "15+ years' experience",
        description: 'Experience supporting learners across schools, colleges, international settings and tuition.',
      },
    ]}
    image={{
      src: tutorImageUrl,
      alt: 'Mr Sheraz teaching maths',
    }}
  >
    <Fragment slot="content">
      <p>
        My name is Mr Sheraz. I founded MathsTutorHelp to give students calm, structured and focused maths support that
        helps them understand the method, practise with purpose and build confidence over time.
      </p>
      <p>
        Many students do not struggle because they lack ability. Often they need clearer explanations, more individual
        attention and a regular routine for practice. MathsTutorHelp is built around that kind of support.
      </p>
    </Fragment>
  </Content>

  <Features
    title="My Teaching Approach"
    subtitle="Lessons are clear, patient and exam-aware without feeling rushed or overwhelming."
    columns={3}
    items={[
      {
        title: 'Clear explanations',
        description: 'Topics are broken into simple steps so students understand the method, not just the answer.',
        icon: 'tabler:chalkboard',
      },
      {
        title: 'Guided practice',
        description: 'Students practise with examples, feedback and questions matched to their current level.',
        icon: 'tabler:pencil-check',
      },
      {
        title: 'Exam technique',
        description: 'GCSE, IGCSE and A-Level students practise exam-style questions and written working.',
        icon: 'tabler:file-check',
      },
      {
        title: 'Confidence building',
        description: 'Lessons give students space to ask questions, revisit gaps and make steady progress.',
        icon: 'tabler:mood-smile',
      },
      {
        title: 'Personalised support',
        description: 'Support is adapted to the student’s level, goals, confidence and areas of difficulty.',
        icon: 'tabler:user-check',
      },
      {
        title: 'Clear next steps',
        description: 'Students can receive targeted practice and guidance on what to improve next.',
        icon: 'tabler:list-check',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-brand-soft dark:bg-transparent"></div>
    </Fragment>
  </Features>

  <Features
    title="Who I Support"
    subtitle="Support is available for students who need confidence, exam preparation or structured help with school topics."
    columns={3}
    items={[
      {
        title: 'KS3 Maths',
        description: 'Years 7-9 foundations before GCSE.',
        icon: 'tabler:school',
      },
      {
        title: 'GCSE Maths',
        description: 'Foundation and Higher support with exam practice.',
        icon: 'tabler:certificate',
      },
      {
        title: 'IGCSE Maths',
        description: 'Topic revision, worked examples and exam technique.',
        icon: 'tabler:calculator',
      },
      {
        title: 'Functional Skills',
        description: 'Practical maths for everyday use and assessments.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'A-Level Maths',
        description: 'Pure maths, statistics, mechanics and problem solving.',
        icon: 'tabler:function',
      },
      {
        title: 'Coding',
        description: 'Beginner Python and problem-solving support.',
        icon: 'tabler:code',
      },
    ]}
  />

  {
    /*
    TODO: Replace this "Local and Online Maths Tuition" Content image with a real photo of Mr Sheraz
    teaching or his actual tutoring setup when that asset is available.
  */
  }
  <Content
    isReversed
    title="Local and Online Maths Tuition"
    items={[
      {
        title: 'Manchester based',
        description: 'Based in Levenshulme, supporting students from Manchester and nearby areas.',
      },
      {
        title: 'Online tuition',
        description: 'Flexible online maths lessons are available for students who prefer learning from home.',
      },
      {
        title: 'Small group classes',
        description: 'GCSE group classes are available for students who benefit from routine and guided practice.',
      },
    ]}
    image={{
      src: siteImages.gallery.classroom,
      alt: 'Levenshulme classroom set up for small group maths tuition',
    }}
  >
    <Fragment slot="content">
      <p>
        MathsTutorHelp supports families looking for structured maths tuition in Manchester and online. Lessons can be
        one-to-one, online, in person or in small groups depending on availability and the student’s needs.
      </p>
    </Fragment>
  </Content>

  <Features
    title="Why Families Choose MathsTutorHelp"
    subtitle="Parents often want tuition that feels professional, steady and easy for students to follow."
    columns={3}
    items={[
      {
        title: 'Teacher-led support',
        description: 'Students are supported by a qualified maths teacher with computer science teaching experience.',
        icon: 'tabler:award',
      },
      {
        title: 'Calm learning environment',
        description: 'Lessons are supportive and structured, helping students feel more confident with maths.',
        icon: 'tabler:heart-handshake',
      },
      {
        title: 'Regular practice',
        description: 'Students can receive worksheets, revision tasks and clear guidance for independent study.',
        icon: 'tabler:book',
      },
    ]}
  />

  <CallToAction
    title="Ready to Talk About Maths Support?"
    subtitle="Tell me the student's level, goals and preferred lesson format. I will help you choose the right next step."
    actions={[
      {
        variant: 'primary',
        text: ctaLabels.freeConsultation,
        href: consultationBookingUrl,
        icon: 'tabler:calendar-check',
      },
      { text: 'View Group Classes', href: groupClassesUrl },
    ]}
  />
</Layout>
