---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';
import { siteImages } from '~/data/images';

const metadata = {
  title: 'Work with Us - Tutors, Marketing Students and Volunteers',
  description:
    'MathsTutorHelp is open to hearing from talented tutors, marketing students, classroom helpers and volunteers interested in supporting students in Manchester and online.',
};

const contactUrl = getPermalink('/contact');
const whatsappUrl =
  'https://wa.me/447860248525?text=Hi%20MathsTutorHelp%2C%20I%20am%20interested%20in%20working%20with%20MathsTutorHelp.';

const opportunities = [
  {
    title: 'Tutors',
    description:
      'Qualified teachers, trainee teachers or confident subject specialists interested in supporting learners.',
    icon: 'tabler:chalkboard',
  },
  {
    title: 'Marketing students',
    description:
      'Students or graduates who can help with social media, local outreach, content ideas and simple campaigns.',
    icon: 'tabler:chart-bar',
  },
  {
    title: 'Classroom helpers',
    description: 'Reliable people who can help with group sessions, resources, setup and student support.',
    icon: 'tabler:users-group',
  },
  {
    title: 'Volunteers',
    description: 'People who want to contribute time, skills or experience to help young people build confidence.',
    icon: 'tabler:heart-handshake',
  },
];

const qualities = [
  {
    title: 'Reliable',
    description: 'You communicate clearly, turn up when agreed and follow safeguarding expectations.',
    icon: 'tabler:calendar-check',
  },
  {
    title: 'Student-focused',
    description: 'You are patient, professional and comfortable supporting young learners.',
    icon: 'tabler:user-check',
  },
  {
    title: 'Practical',
    description: 'You are happy to help with real tasks, from tutoring and resources to outreach and admin.',
    icon: 'tabler:list-check',
  },
];
---

<Layout metadata={metadata}>
  <Hero
    tagline="Work with MathsTutorHelp"
    title="Work with MathsTutorHelp"
    subtitle="MathsTutorHelp is looking for talented people, tutors, marketing students, classroom helpers and volunteers who want to support students in Manchester and online."
    actions={[
      { variant: 'primary', text: 'Send Your Interest', href: whatsappUrl, icon: 'tabler:brand-whatsapp' },
      { text: 'Contact MathsTutorHelp', href: contactUrl },
    ]}
    image={{
      src: siteImages.supportAssistant,
      alt: 'Maths tutoring and classroom support',
    }}
  />

  <Features
    title="Opportunities"
    subtitle="This page is for people who may be a good fit now or in the future."
    columns={4}
    items={opportunities}
  />

  <section class="bg-brand-soft py-14 dark:bg-slate-900">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">About the Role</p>
          <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white">Help MathsTutorHelp Grow</h2>
          <p class="mt-4 text-lg leading-8 text-muted dark:text-slate-300">
            MathsTutorHelp is open to hearing from people who can add value through teaching, student support,
            marketing, content, administration, local outreach or volunteering. Some opportunities may be paid, some may
            be project based, and some may suit students looking for useful experience.
          </p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800">
          <h3 class="text-2xl font-bold text-gray-950 dark:text-white">Useful Details</h3>
          <ul class="mt-5 space-y-3 text-base leading-7 text-muted dark:text-slate-300">
            <li class="flex gap-3">
              <span class="mt-3 size-2 rounded-full bg-secondary" aria-hidden="true"></span>
              <span>Location: Levenshulme, Manchester and online.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-3 size-2 rounded-full bg-secondary" aria-hidden="true"></span>
              <span>Flexible opportunities depending on current needs.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-3 size-2 rounded-full bg-secondary" aria-hidden="true"></span>
              <span>Paid, voluntary or experience-based roles may be considered.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-3 size-2 rounded-full bg-secondary" aria-hidden="true"></span>
              <span>DBS and safeguarding checks may be required for student-facing work.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <Features
    title="What We Look For"
    subtitle="You do not need to fit one exact job title. The main thing is reliability, professionalism and a genuine interest in helping students."
    columns={3}
    items={qualities}
  />

  <section class="bg-white py-14 dark:bg-slate-900">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="rounded-lg border border-gray-200 bg-brand-soft p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800">
        <div class="grid gap-5 md:grid-cols-[1fr_auto] md:items-center">
          <div>
            <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">How to Apply</p>
            <h2 class="mt-2 text-2xl font-bold text-gray-950 dark:text-white">Send Your Interest</h2>
            <p class="mt-3 text-base leading-7 text-muted dark:text-slate-300">
              Send a short message with your skills, availability and the type of work you are interested in. You can
              include a CV, portfolio, social media examples or tutoring background if relevant.
            </p>
          </div>
          <a class="btn-primary justify-center" href={whatsappUrl}>Message Your Interest</a>
        </div>
      </div>
    </div>
  </section>

  <CallToAction
    title="Interested in Working with MathsTutorHelp?"
    subtitle="Send a short note about your skills, availability and whether you are interested in tutoring, marketing, classroom support or volunteering."
    actions={[
      { variant: 'primary', text: 'Send Your Interest', href: whatsappUrl, icon: 'tabler:brand-whatsapp' },
      { text: 'Contact MathsTutorHelp', href: contactUrl },
    ]}
  />
</Layout>
