---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';
import { bookingLinks, contactDetails, ctaLabels, tuitionPrices } from '~/utils/siteDetails';
import { siteImages } from '~/data/images';

const metadata = {
  title: 'MathsTutorHelp GCSE Higher Maths Classes Manchester',
  description:
    'MathsTutorHelp structured weekly GCSE Higher Maths sessions in Manchester for Year 10 and 11 students aiming for grades 6-9.',
};

const interestFormUrl = bookingLinks.groupClassInterest;
const contactUrl = getPermalink('/contact');
const foundationClassUrl = getPermalink('/gcse-foundation-maths-tutoring-club-2025');
const onlineTuitionUrl = getPermalink('/online-tuition');
const phoneDisplay = contactDetails.phoneDisplay;
const eventSchema = {
  '@context': 'https://schema.org',
  '@type': 'EducationEvent',
  name: 'MathsTutorHelp GCSE Higher Maths Classes Manchester',
  description: metadata.description,
  url: String(Astro.url),
  startDate: '2026-09-13T11:00:00+01:00',
  endDate: '2027-05-30T12:00:00+01:00',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  eventStatus: 'https://schema.org/EventScheduled',
  location: {
    '@type': 'Place',
    name: 'Levenshulme High School',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Crossley Road',
      addressLocality: 'Levenshulme',
      addressRegion: 'Manchester',
      postalCode: 'M19 1FS',
      addressCountry: 'GB',
    },
  },
  organizer: {
    '@type': 'EducationalOrganization',
    name: 'MathsTutorHelp',
    url: String(new URL(getPermalink('/'), Astro.site)),
    telephone: contactDetails.phoneDisplay,
  },
  offers: {
    '@type': 'Offer',
    price: '20',
    priceCurrency: 'GBP',
    availability: 'https://schema.org/LimitedAvailability',
    url: interestFormUrl,
  },
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(eventSchema)} />

  <Hero
    tagline="MathsTutorHelp GCSE Higher Maths"
    title="MathsTutorHelp GCSE Higher Maths Classes Manchester"
    subtitle="Structured weekly MathsTutorHelp sessions in Manchester designed to help Year 10 and 11 Higher Tier students master key topics, build confidence and succeed in GCSE Maths."
    actions={[
      {
        variant: 'primary',
        text: ctaLabels.groupClassInterest,
        href: interestFormUrl,
        target: '_blank',
        icon: 'tabler:calendar-check',
      },
      { text: 'Contact MathsTutorHelp', href: contactUrl },
    ]}
    image={{
      src: siteImages.gallery.circleTheorems,
      alt: 'GCSE Maths board work from a real class',
    }}
  />

  <Features
    title="Class Details"
    subtitle="A small, focused GCSE Higher Maths group for students who need regular support, exam practice and clear feedback."
    columns={3}
    items={[
      {
        title: 'Year 10 and Year 11',
        description: 'For Higher Tier students aiming for grades 6-9.',
        icon: 'tabler:users',
      },
      {
        title: 'Sundays, 11:00am-12:00pm',
        description: 'Weekly classes from 13 September 2026 to May 2027.',
        icon: 'tabler:clock',
      },
      {
        title: 'Levenshulme High School',
        description: 'Manchester, M19 1FS. Local in-person support in a structured classroom setting.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Maximum 7 students',
        description: 'Small group size for personalised attention and a calmer learning environment.',
        icon: 'tabler:users-group',
      },
      {
        title: 'Flexible pricing',
        description: `${tuitionPrices.smallGroup.display} pay-as-you-go, or £16 per lesson with advance block booking.`,
        icon: 'tabler:coin-pound',
      },
      {
        title: 'Paper-based learning',
        description: 'No screens in class, just focused GCSE-style practice and written working.',
        icon: 'tabler:file-pencil',
      },
    ]}
  />

  <Content
    isReversed
    title="What Students Get"
    items={[
      {
        title: 'Clear Higher topic teaching',
        description: 'Key GCSE Higher topics are explained clearly, with methods students can apply in exams.',
      },
      {
        title: 'Diagnostic-led planning',
        description: 'Lessons are shaped around the topics students find difficult and the skills they need for exams.',
      },
      {
        title: 'Exam question practice',
        description: 'Students practise GCSE-style questions, learn how to show working and review common mistakes.',
      },
      {
        title: 'Paper-based learning',
        description: 'No screens in class, just structured, focused study that reflects real exam conditions.',
      },
      {
        title: 'Homework and materials',
        description:
          'Students can bring schoolwork, use tutor-provided materials or access bonus tasks and past papers.',
      },
    ]}
    image={{
      src: siteImages.higherMathsNotes,
      alt: 'GCSE Higher Maths revision notes',
    }}
  >
    <Fragment slot="content">
      <p>
        This Higher Tier group is for learners who want structured weekly support, focused revision and clear teaching
        from an experienced GCSE Maths teacher.
      </p>
    </Fragment>
  </Content>

  <Features
    title="Course Plan and Exam Dates"
    subtitle="Students follow a structured programme that builds towards the 2027 GCSE Maths papers."
    columns={3}
    items={[
      {
        title: 'Full Scheme of Work',
        description: 'The full course plan can be shared when you register interest or ask about the class.',
        icon: 'tabler:file-download',
      },
      {
        title: '2027 Paper 1',
        description: 'GCSE Maths Paper 1: 13 May 2027.',
        icon: 'tabler:calendar',
      },
      {
        title: '2027 Paper 2',
        description: 'GCSE Maths Paper 2: 19 May 2027.',
        icon: 'tabler:calendar',
      },
      {
        title: '2027 Paper 3',
        description: 'GCSE Maths Paper 3: 2 June 2027.',
        icon: 'tabler:calendar',
      },
      {
        title: 'AQA, Edexcel and OCR',
        description: 'Tasks are adapted to your child’s exam board and specification, including AQA, Edexcel and OCR.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Holiday classes',
        description: 'Holiday session dates are shared by WhatsApp and email when available.',
        icon: 'tabler:sun',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-brand-soft dark:bg-transparent"></div>
    </Fragment>
  </Features>

  <Content
    title="Booking and Attendance"
    items={[
      {
        title: 'Reserve a place first',
        description: 'A place should be reserved before attending, as class numbers are limited.',
      },
      {
        title: 'Pay flexibly',
        description: 'Students can pay at the door once their place is reserved, or ask about block booking.',
      },
      {
        title: 'Join mid-way',
        description: 'Students can join during the year where spaces are available.',
      },
    ]}
    image={{
      src: siteImages.gallery.classroom,
      alt: 'Levenshulme classroom set up for small group maths tuition',
    }}
  >
    <Fragment slot="content">
      <p>
        Book the full term to secure your child’s place, or attend flexibly once a space has been reserved. Places are
        limited because the class is kept small for focused support.
      </p>
    </Fragment>
  </Content>

  <FAQs
    title="Frequently Asked Questions"
    subtitle="Answers for parents considering the GCSE Higher Maths class."
    columns={2}
    items={[
      {
        title: 'What if my child misses a session?',
        description: 'Let us know in advance. Where possible, your child can attend the next suitable session.',
      },
      {
        title: 'Is homework given?',
        description: 'Yes. Optional worksheets are provided, and students can also bring schoolwork for support.',
      },
      {
        title: 'How is progress tracked?',
        description: 'Progress is tracked with mock tasks, diagnostic reviews and regular tutor feedback.',
      },
      {
        title: 'Do students use computers in class?',
        description: 'No. Work is paper-based to reflect real exam conditions and reduce distractions.',
      },
      {
        title: 'Can my child join mid-way through the term?',
        description:
          'Yes. Students can join mid-way if a place is available. The first session includes a diagnostic check.',
      },
      {
        title: 'What exam boards do you cover?',
        description: 'AQA, Edexcel and OCR are covered, with tasks tailored to your child’s specification.',
      },
      {
        title: 'Is this suitable for Foundation Tier students?',
        description: `This class is for Higher Tier. Foundation students can view the Foundation group here: <a class="underline" href="${foundationClassUrl}">GCSE Foundation class</a>.`,
      },
      {
        title: 'Do you run sessions during school holidays?',
        description: 'Yes. Holiday class dates are shared via WhatsApp and email.',
      },
      {
        title: 'Can parents get feedback?',
        description: 'Yes. Updates can be shared by WhatsApp or email on request.',
      },
      {
        title: 'Is there a free trial?',
        description: 'Ask about current trial or first-session arrangements when you register interest.',
      },
      {
        title: 'Who teaches the class?',
        description:
          'The class is taught by Mr Sheraz, a qualified and DBS-checked maths teacher with 15+ years of teaching experience.',
      },
      {
        title: 'Is there an online option?',
        description: `Students who prefer learning from home can view online tuition options here: <a class="underline" href="${onlineTuitionUrl}">Online Maths Tuition</a>.`,
      },
    ]}
  />

  <CallToAction
    title="Book a GCSE Higher Maths Place"
    subtitle={`Limited spaces are available. Book early to ask about the £16 advance block booking rate, or call/WhatsApp ${phoneDisplay} if you have questions.`}
    actions={[
      {
        variant: 'primary',
        text: ctaLabels.groupClassInterest,
        href: interestFormUrl,
        target: '_blank',
        icon: 'tabler:calendar-check',
      },
      { text: 'Ask About One-to-One Tuition', href: contactUrl },
    ]}
  />
</Layout>
