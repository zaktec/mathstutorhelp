---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';
import { tuitionPrices } from '~/utils/siteDetails';
import { siteImages } from '~/data/images';

const metadata = {
  title: 'Maths Levels - Year 6, KS3, GCSE, IGCSE, A-Level & Functional Skills',
  description:
    'MathsTutorHelp supports Year 6, KS3, GCSE, IGCSE, A-Level, Functional Skills and beginner coding learners in Manchester and online.',
};

const contactUrl = getPermalink('/contact');
const mathsTuitionUrl = getPermalink('/maths-tuition');
const pricingUrl = getPermalink('/pricing');

const mathsLevels = [
  {
    title: 'Year 6 Maths',
    description: 'Challenge Maths Club support for Year 6 learners preparing for secondary school.',
    icon: 'tabler:school',
  },
  {
    title: 'KS3 Maths',
    description: 'Secondary school maths for Years 7, 8 and 9, covering the foundations needed before GCSE.',
    icon: 'tabler:books',
  },
  {
    title: 'GCSE Maths',
    description:
      'Secondary school GCSE support for Years 10 and 11 across exam boards, including Foundation and Higher.',
    icon: 'tabler:certificate',
  },
  {
    title: 'IGCSE Maths',
    description: 'International GCSE support for learners following Cambridge or Edexcel curriculum routes.',
    icon: 'tabler:world',
  },
  {
    title: 'A-Level Maths',
    description: 'College-level support for Years 12 and 13, including pure maths, mechanics and statistics.',
    icon: 'tabler:chart-line',
  },
  {
    title: 'Functional Skills',
    description: 'Practical maths support for adult learners working towards Functional Skills Level 1 or Level 2.',
    icon: 'tabler:list-check',
  },
  {
    title: 'Adult Numeracy',
    description: 'Numeracy support for adult learners who do not yet have a Level 1 or Level 2 maths grade.',
    icon: 'tabler:calculator',
  },
  {
    title: 'Beginner Coding',
    description: 'Beginner Python and problem-solving support for students who want to build confidence with coding.',
    icon: 'tabler:code',
  },
];

const priceOptions = [
  {
    title: 'Online Tutoring',
    price: tuitionPrices.online.display,
    detail: 'Live online maths tuition for focused support from home.',
  },
  {
    title: 'In-Person Tutoring',
    price: tuitionPrices.oneToOne.display,
    detail: 'Face-to-face maths tuition for students who prefer in-person learning.',
  },
  {
    title: 'Group Session',
    price: tuitionPrices.smallGroup.display,
    detail: 'Small group maths support for learners who benefit from shared practice.',
  },
];
---

<Layout metadata={metadata}>
  <Hero
    tagline="Maths Levels"
    title="Maths Support by Level"
    subtitle="MathsTutorHelp supports Year 6, KS3, GCSE, IGCSE, A-Level, Functional Skills, adult numeracy and beginner coding learners."
    actions={[
      { variant: 'primary', text: 'Find the Right Support', href: contactUrl, icon: 'tabler:school' },
      { text: 'View Tuition Services', href: mathsTuitionUrl },
    ]}
    image={{
      src: siteImages.tuition,
      alt: 'Maths tuition support for different levels',
    }}
  />

  <Features
    title="Levels We Cover"
    subtitle="Beginner, intermediate and advanced learners are catered for, with tuition adapted to the curriculum, student confidence and the topics causing the most difficulty."
    columns={3}
    items={mathsLevels}
  />

  <section class="bg-brand-soft py-14 dark:bg-slate-900">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
        <div>
          <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Diagnostic Support</p>
          <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white">
            Bespoke Support for Difficult Topics
          </h2>
          <p class="mt-4 text-lg leading-8 text-muted dark:text-slate-300">
            MathsTutorHelp offers bespoke packages that focus on the core topics causing the most difficulty. Diagnostic
            tests can accompany the initial contact with one student or multiple pupils, so the right next steps can be
            planned from the start.
          </p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800">
          <h3 class="text-2xl font-bold text-gray-950 dark:text-white">How We Choose the Right Level</h3>
          <ul class="mt-5 space-y-3 text-base leading-7 text-muted dark:text-slate-300">
            <li class="flex gap-3">
              <span class="mt-3 size-2 rounded-full bg-secondary" aria-hidden="true"></span>
              <span>Identify the student's year group, current curriculum and exam board where relevant.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-3 size-2 rounded-full bg-secondary" aria-hidden="true"></span>
              <span>Use diagnostic questions to find the topics that need the most attention.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-3 size-2 rounded-full bg-secondary" aria-hidden="true"></span>
              <span>Create a tuition plan that suits the learner's confidence, goals and available time.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-14 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">Prices</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-950 dark:text-white md:text-4xl">Our Prices</h2>
        <p class="mt-4 text-lg leading-8 text-muted dark:text-slate-300">
          A simple guide to the main tuition options available.
        </p>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {
          priceOptions.map((option) => (
            <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800">
              <h3 class="text-xl font-bold text-gray-950 dark:text-white">{option.title}</h3>
              <p class="mt-5 text-4xl font-extrabold tracking-tight text-primary">{option.price}</p>
              <p class="mt-4 text-base leading-7 text-muted dark:text-slate-300">{option.detail}</p>
            </article>
          ))
        }
      </div>
      <div class="mt-8 text-center">
        <a class="btn-secondary justify-center" href={pricingUrl}>View Current Tuition Prices</a>
      </div>
    </div>
  </section>

  <FAQs
    title="Maths Levels FAQs"
    columns={2}
    items={[
      {
        title: 'Do you support Year 6 students?',
        description: 'Yes. Year 6 support is available for learners preparing for secondary school maths.',
      },
      {
        title: 'Do you support beginner coding?',
        description:
          'Yes. Beginner Python and problem-solving support is available for students who want to learn coding.',
      },
      {
        title: 'Which secondary levels are covered?',
        description: 'Support is available for KS3, GCSE, IGCSE and A-Level maths across different exam routes.',
      },
      {
        title: 'Do you work with adult learners?',
        description: 'Yes. Adult numeracy and Functional Skills Level 1 or Level 2 support is available.',
      },
    ]}
  />

  <CallToAction
    title="Not Sure Which Level to Choose?"
    subtitle="Send a short message with the student's year group, exam board and main concerns. We will point you to the right support."
    actions={[{ variant: 'primary', text: 'Ask About Maths Support', href: contactUrl, icon: 'tabler:message' }]}
  />
</Layout>
