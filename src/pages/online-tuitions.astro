---
import { getPermalink } from '~/utils/permalinks';

const destination = getPermalink('/online-tuition');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${destination}`} />
    <link rel="canonical" href={destination} />
    <title>Redirecting to Online Maths Tuition</title>
  </head>
  <body>
    <p>Redirecting to <a href={destination}>Online Maths Tuition</a>.</p>
  </body>
</html>
