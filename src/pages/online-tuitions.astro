---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Online Courses',
  description:
    'Learn from home with flexible, affordable online maths tuition for KS3, GCSE, IGCSE, Functional Skills and A-Level students.',
};

const consultationBookingUrl = 'https://calendar.app.google/VJ6tgEKfsUZAncDe9';
const contactUrl = '/contact';

const packages = [
  {
    title: 'Bronze Package',
    sessions: '1 online session per month',
    price: '£25/month',
  },
  {
    title: 'Silver Package',
    sessions: '2 online sessions per month',
    price: '£45/month',
  },
  {
    title: 'Gold Package',
    sessions: '4 online sessions per month',
    price: '£80/month',
  },
];
---

<Layout metadata={metadata}>
  <Hero
    tagline="Online Courses"
    title="Online Maths Tutoring Packages"
    subtitle="Learn from home with flexible, affordable online maths tuition. Sessions are personalised, structured and supported by access to our online learning platform for extra practice anytime."
    actions={[
      { variant: 'primary', text: 'Book Online Tuition', href: consultationBookingUrl, icon: 'tabler:video' },
      { text: 'Contact Us', href: contactUrl },
    ]}
    image={{
      src: 'https://i0.wp.com/mathstutorhelp.com/wp-content/uploads/2024/06/onlinemathstutorings-scaled.jpg?fit=1800%2C1200&ssl=1',
      alt: 'Online maths tutoring packages',
    }}
  />

  <Features
    title="Why Choose Online Tuition?"
    subtitle="No travel, no stress. Just effective maths support from home for KS3, GCSE, IGCSE, Functional Skills and A-Level students."
    columns={3}
    items={[
      {
        title: 'Learn from anywhere',
        description: 'Lessons are laptop and tablet friendly, so students can learn from home or another quiet space.',
        icon: 'tabler:device-laptop',
      },
      {
        title: 'Affordable support',
        description: 'A flexible alternative to private home tutoring, with simple monthly package options.',
        icon: 'tabler:coin-pound',
      },
      {
        title: 'Flexible scheduling',
        description: 'Book support around school, revision, activities and family routines.',
        icon: 'tabler:calendar-time',
      },
      {
        title: 'Personalised pace',
        description: 'Lessons can slow down for difficult topics or move faster when confidence grows.',
        icon: 'tabler:adjustments',
      },
      {
        title: 'Platform resources',
        description: 'Students get access to resources, worksheets and learning platform practice between sessions.',
        icon: 'tabler:books',
      },
      {
        title: 'Exam preparation',
        description: 'Great for confidence building, topic revision and exam-style practice.',
        icon: 'tabler:file-pencil',
      },
    ]}
  />

  <section class="bg-white py-16 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-base font-semibold uppercase tracking-wide text-primary">1:1 Online Tutoring</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 dark:text-white md:text-4xl">
          Choose the package that suits your child
        </h2>
        <p class="mt-4 text-lg text-muted dark:text-slate-400">
          Each booking is a 55-minute live online session with focused teaching, guided practice and clear next steps.
        </p>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {
          packages.map((item) => (
            <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800">
              <h3 class="text-xl font-bold text-gray-900 dark:text-white">{item.title}</h3>
              <p class="mt-3 text-muted dark:text-slate-300">{item.sessions}</p>
              <p class="mt-6 text-3xl font-extrabold text-primary">{item.price}</p>
            </article>
          ))
        }
      </div>

      <div class="mt-8 rounded-lg border border-gray-200 bg-gray-50 p-6 dark:border-gray-700 dark:bg-slate-800">
        <h3 class="text-xl font-bold text-gray-900 dark:text-white">Every one-to-one package includes</h3>
        <div class="mt-5 grid gap-3 text-muted dark:text-slate-300 sm:grid-cols-2 lg:grid-cols-3">
          <p>Diagnostic test and personalised learning plan</p>
          <p>Access to the online platform and learner resources</p>
          <p>Custom online worksheet after every session</p>
          <p>Fully qualified and DBS-checked tutor</p>
          <p>No contracts, cancel anytime</p>
          <p>Support for KS3, GCSE, IGCSE, Functional Skills and A-Level</p>
        </div>
      </div>
    </div>
  </section>

  <Content
    title="A Typical Online Session"
    subtitle="Interactive online tuition keeps lessons focused, clear and easy to follow."
    items={[
      {
        title: 'Live teaching',
        description: 'Clear explanations with guided examples and space for questions.',
        icon: 'tabler:presentation',
      },
      {
        title: 'Digital whiteboard',
        description: 'Screen-sharing and shared working help students follow each method step by step.',
        icon: 'tabler:chalkboard',
      },
      {
        title: 'Exam-style questions',
        description: 'Practice includes reasoning, topic breakdowns and exam preparation.',
        icon: 'tabler:file-analytics',
      },
      {
        title: 'Follow-up tasks',
        description: 'Homework or revision tasks help students keep improving between lessons.',
        icon: 'tabler:clipboard-check',
      },
    ]}
    columns={2}
    image={{
      src: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=1400&q=80',
      alt: 'Online study setup',
    }}
  >
    <Fragment slot="content">
      <p>
        Students receive structured support during the lesson and platform access for additional revision outside
        lesson time.
      </p>
    </Fragment>
  </Content>

  <Content
    title="Online Group Classes"
    subtitle="Interactive online group sessions are planned to start in September."
    items={[
      {
        title: '£15 per learner',
        description: 'Simple per-session pricing for online group learning.',
        icon: 'tabler:coin-pound',
      },
      {
        title: 'Maximum 6 learners',
        description: 'Small groups keep sessions interactive and manageable.',
        icon: 'tabler:users-group',
      },
      {
        title: 'Revision and exam practice',
        description: 'Sessions include topic breakdowns, guided revision and exam-style questions.',
        icon: 'tabler:file-pencil',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1606761568499-6d2451b23c66?auto=format&fit=crop&w=1400&q=80',
      alt: 'Small online class learning together',
    }}
    isReversed
    isAfterContent
  >
    <Fragment slot="content">
      <p>
        Join the waiting list to be notified when enrolment opens and suitable group times are available.
      </p>
    </Fragment>
  </Content>

  <FAQs
    title="Online Tuition FAQs"
    columns={2}
    items={[
      {
        title: 'Which levels can be taught online?',
        description: 'Online tuition is available for KS3, GCSE, IGCSE, A-Level and Functional Skills maths.',
      },
      {
        title: 'How long is each lesson?',
        description: 'Each live online booking is a 55-minute session.',
      },
      {
        title: 'Does online tuition include exam practice?',
        description: 'Yes. Lessons can include topic revision, past papers, worksheets and exam-style questions.',
      },
      {
        title: 'What does the student need?',
        description: 'A reliable internet connection, a quiet place to work and a device suitable for video lessons.',
      },
      {
        title: 'Can we switch between online and in-person?',
        description: 'Yes, where availability allows. Many families use a mix depending on timetable and location.',
      },
    ]}
  />

  <CallToAction
    title="Ready to Get Started?"
    subtitle="WhatsApp 07860 248525 or fill in the contact form and we will reply with available time slots."
    actions={[
      {
        variant: 'primary',
        text: 'Contact MathsTutorHelp',
        href: contactUrl,
        icon: 'tabler:calendar-check',
      },
    ]}
  />
</Layout>
