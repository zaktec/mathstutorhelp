---
import { getPermalink } from '~/utils/permalinks';

interface Props {
  currentPage: number;
  totalPages: number;
}

const { currentPage, totalPages } = Astro.props;
const pageUrl = (page: number) => getPermalink(page === 1 ? '/blog' : `/blog/page/${page}`);
---

{
  totalPages > 1 && (
    <nav class="mx-auto mt-10 flex max-w-7xl items-center justify-between px-4 sm:px-6" aria-label="Blog pages">
      {currentPage > 1 ? (
        <a class="btn-secondary" href={pageUrl(currentPage - 1)}>
          Previous
        </a>
      ) : (
        <span />
      )}
      <span class="text-sm text-muted dark:text-slate-300">
        Page {currentPage} of {totalPages}
      </span>
      {currentPage < totalPages ? (
        <a class="btn-secondary" href={pageUrl(currentPage + 1)}>
          Next
        </a>
      ) : (
        <span />
      )}
    </nav>
  )
}
