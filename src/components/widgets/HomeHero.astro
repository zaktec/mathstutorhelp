---
import { Icon } from 'astro-icon/components';
import Button from '~/components/ui/Button.astro';
import Image from '~/components/common/Image.astro';
import { getPermalink } from '~/utils/permalinks';
import { contactDetails, ctaLabels } from '~/utils/siteDetails';
import tutorImage from '~/assets/images/maths-tutor-sheraz-cheema.jpeg';

const { groupClassInterestUrl, tuitionOptionsUrl = getPermalink('/maths-tuition/') } = Astro.props;

const trustPoints = [
  { text: 'Qualified teacher', icon: 'tabler:certificate' },
  { text: 'DBS checked', icon: 'tabler:shield-check' },
  { text: "15+ years' experience", icon: 'tabler:award' },
  { text: 'Manchester based', icon: 'tabler:map-pin' },
  { text: 'GCSE, IGCSE, Functional Skills and A-Level', icon: 'tabler:math-function' },
  { text: 'Online and in-person tuition', icon: 'tabler:device-laptop' },
];
---

<section class="relative md:-mt-[76px] not-prose overflow-hidden">
  <div class="absolute inset-0 bg-brand-soft dark:bg-page-dark" aria-hidden="true"></div>
  <div class="absolute inset-x-0 bottom-0 h-10 bg-page dark:bg-page-dark" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6">
    <div class="pt-0 md:pt-[76px] pointer-events-none"></div>
    <div
      class="grid items-center gap-6 py-7 md:grid-cols-[minmax(0,1.12fr)_minmax(300px,0.88fr)] md:gap-10 md:py-8 lg:py-10"
    >
      <div class="max-w-3xl">
        <p class="mb-3 text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">MathsTutorHelp</p>
        <h1
          class="font-heading text-4xl font-bold leading-tight text-gray-950 dark:text-white sm:text-5xl lg:text-[3.35rem]"
        >
          Maths Tutor in Manchester for GCSE, KS3 and A-Level
        </h1>
        <p class="mt-4 max-w-2xl text-lg font-semibold leading-relaxed text-primary dark:text-slate-100">
          Clear, structured maths tuition in Manchester and online, led by Mr Sheraz, a qualified and DBS-checked
          teacher with 15+ years' experience.
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <Button
            variant="primary"
            text={ctaLabels.groupClassInterest}
            href={groupClassInterestUrl}
            icon="tabler:calendar-check"
            class="w-full sm:w-auto"
          />
          <Button
            text="View Tuition Options"
            href={tuitionOptionsUrl}
            icon="tabler:chevron-right"
            class="w-full sm:w-auto"
          />
        </div>
        <div
          class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm font-bold text-gray-800 dark:text-slate-200"
          aria-label="Tutor credentials"
        >
          <span>Qualified Teacher</span>
          <span class="text-secondary dark:text-teal-200" aria-hidden="true">•</span>
          <span>DBS Checked</span>
          <span class="text-secondary dark:text-teal-200" aria-hidden="true">•</span>
          <span>15+ Years' Experience</span>
          <span class="text-secondary dark:text-teal-200" aria-hidden="true">•</span>
          <span>Manchester Based</span>
        </div>
      </div>

      <aside
        class="mx-auto w-full max-w-xs overflow-hidden rounded-lg border border-primary/15 bg-white shadow-xl shadow-slate-900/10 dark:border-slate-700 dark:bg-slate-900 md:max-w-sm lg:max-w-[340px]"
      >
        <div class="bg-brand-soft">
          <Image
            src={tutorImage}
            alt="Mr Sheraz teaching GCSE Maths at a whiteboard"
            width={1448}
            height={1086}
            widths={[320, 400, 680]}
            sizes="(max-width: 767px) 100vw, 340px"
            format="webp"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="w-full object-cover"
          />
        </div>

        <div class="bg-brand-soft/70 px-4 pb-4 pt-4 dark:bg-slate-900">
          <p class="text-xl font-bold text-gray-950 dark:text-white">Mr Sheraz</p>
          <p class="mt-1 font-semibold text-secondary dark:text-teal-200">Qualified Maths Teacher</p>
          <a
            class="mt-3 inline-flex items-center gap-2 rounded-md border border-primary/20 bg-white px-3 py-2 text-sm font-bold text-primary hover:bg-primary hover:text-white dark:border-slate-700 dark:bg-slate-800 dark:text-teal-200"
            href={contactDetails.phoneHref}
          >
            <Icon name="tabler:phone" class="h-4 w-4" />
            Call {contactDetails.phoneDisplay}
          </a>

          <ul class="mt-4 grid gap-2">
            {
              trustPoints.map((point) => (
                <li class="flex gap-2 text-sm leading-5 text-muted dark:text-slate-300">
                  <Icon name={point.icon} class="mt-0.5 h-4 w-4 shrink-0 text-secondary dark:text-teal-200" />
                  <span>{point.text}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </aside>
    </div>
  </div>
</section>
