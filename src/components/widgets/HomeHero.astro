---
import { Icon } from 'astro-icon/components';
import Button from '~/components/ui/Button.astro';
import { getAsset, getPermalink } from '~/utils/permalinks';

const {
  groupClassInterestUrl,
  tuitionOptionsUrl = getPermalink('/maths-tuition/'),
} = Astro.props;
const tutorImageUrl = getAsset('/images/maths-tutor-sheraz-cheema.jpeg');

const trustPoints = [
  { text: "15+ years' experience", icon: 'tabler:award' },
  { text: 'DBS checked', icon: 'tabler:shield-check' },
  { text: 'GCSE, IGCSE, Functional Skills and A-Level', icon: 'tabler:math-function' },
  { text: 'Online and in-person tuition', icon: 'tabler:device-laptop' },
  { text: 'Manchester based', icon: 'tabler:map-pin' },
];
---

<section class="relative md:-mt-[76px] not-prose overflow-hidden">
  <div class="absolute inset-0 bg-brand-soft dark:bg-page-dark" aria-hidden="true"></div>
  <div class="absolute inset-x-0 bottom-0 h-24 bg-page dark:bg-page-dark" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6">
    <div class="pt-0 md:pt-[76px] pointer-events-none"></div>
    <div
      class="grid items-center gap-8 py-10 md:grid-cols-[minmax(0,1.08fr)_minmax(360px,0.92fr)] md:gap-12 md:py-12 lg:py-14"
    >
      <div class="max-w-3xl">
        <p class="mb-4 text-sm font-bold uppercase tracking-wide text-secondary dark:text-teal-200">MathsTutorHelp</p>
        <h1 class="font-heading text-4xl font-bold leading-tight text-gray-950 dark:text-white sm:text-5xl lg:text-6xl">
          Maths Tutor in Manchester for GCSE, IGCSE and A-Level
        </h1>
        <p class="mt-6 max-w-2xl text-xl font-semibold leading-relaxed text-primary dark:text-slate-100">
          Small group GCSE classes in Levenshulme and online one-to-one maths tuition with a qualified, DBS-checked
          teacher.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button
            variant="primary"
            text="Register Your Interest"
            href={groupClassInterestUrl}
            icon="tabler:calendar-check"
            class="w-full sm:w-auto"
          />
          <Button
            text="View Tuition Options"
            href={tuitionOptionsUrl}
            icon="tabler:chevron-right"
            class="w-full border-2 border-primary bg-brand-soft text-primary hover:bg-primary hover:text-white sm:w-auto"
          />
        </div>
      </div>

      <aside
        class="mx-auto w-full max-w-sm overflow-hidden rounded-lg border border-primary/15 bg-white shadow-xl shadow-slate-900/10 dark:border-slate-700 dark:bg-slate-900"
      >
        <div class="bg-brand-soft">
          <img
            src={tutorImageUrl}
            alt="Mr Sheraz Cheema teaching GCSE Maths at a whiteboard"
            width={1448}
            height={1086}
            sizes="(max-width: 767px) 100vw, 420px"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="w-full object-cover"
          />
        </div>

        <div class="bg-brand-soft/70 px-5 pb-5 pt-5 dark:bg-slate-900">
          <p class="text-2xl font-bold text-gray-950 dark:text-white">Mr Sheraz Cheema</p>
          <p class="mt-1 font-semibold text-secondary dark:text-teal-200">Qualified Maths Teacher</p>

          <ul class="mt-5 space-y-3">
            {
              trustPoints.map((point) => (
                <li class="flex gap-3 text-sm leading-6 text-muted dark:text-slate-300">
                  <Icon name={point.icon} class="mt-0.5 h-5 w-5 shrink-0 text-secondary dark:text-teal-200" />
                  <span>{point.text}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </aside>
    </div>
  </div>
</section>
