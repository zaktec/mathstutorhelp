---
import { Icon } from 'astro-icon/components';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], links = [], footNote = '', theme = 'light' } = Astro.props;
---

<footer
  class:list={[
    { dark: theme === 'dark' },
    'relative border-t border-gray-200 dark:border-footer-border not-prose',
    { 'bg-footer text-white': theme === 'dark' },
  ]}
>
  <div
    class:list={['absolute inset-0 pointer-events-none', theme === 'dark' ? 'bg-footer' : 'dark:bg-dark']}
    aria-hidden="true"
  >
  </div>
  <div
    class:list={[
      'relative max-w-7xl mx-auto px-4 sm:px-6 intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade',
      theme === 'dark' ? 'text-white' : 'dark:text-slate-300',
    ]}
  >
    <div class="py-6 md:py-8">
      <div class="mx-auto grid max-w-5xl gap-5 text-center sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-5">
        {
          links.map(({ title, links }) => (
            <div>
              <div class:list={['mb-2 text-sm font-semibold', theme === 'dark' ? 'text-white' : 'dark:text-gray-300']}>
                {title}
              </div>
              {links && Array.isArray(links) && links.length > 0 && (
                <ul class="text-sm leading-5">
                  {links.map(({ text, href, ariaLabel }) => (
                    <li>
                      <a
                        class:list={[
                          'inline-flex items-center py-1 hover:underline transition duration-150 ease-in-out',
                          theme === 'dark'
                            ? 'text-white/85 hover:text-accent'
                            : 'text-muted hover:text-gray-700 dark:text-gray-400',
                        ]}
                        href={href}
                        aria-label={ariaLabel}
                      >
                        <Fragment set:html={text} />
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ))
        }
      </div>
    </div>
    <div class="flex flex-col items-center justify-center gap-2 border-t border-white/10 py-3 text-center sm:flex-row">
      <p class="text-xs font-semibold uppercase tracking-wide text-white/60">Exam boards supported</p>
      <div class="flex flex-wrap justify-center gap-2">
        {
          ['Edexcel', 'AQA', 'OCR'].map((board) => (
            <span class="rounded-md border border-white/20 bg-white/10 px-2.5 py-1 text-xs font-bold tracking-wide text-white/90">
              {board}
            </span>
          ))
        }
      </div>
    </div>
    <div class="flex flex-col items-center justify-center gap-2 py-3 text-center">
      {
        socialLinks?.length ? (
          <ul class="flex flex-wrap justify-center">
            {socialLinks.map(({ ariaLabel, href, text, icon }) => (
              <li>
                <a
                  class:list={[
                    'focus:outline-none focus:ring-4 h-9 w-9 justify-center rounded-lg text-sm inline-flex items-center',
                    theme === 'dark'
                      ? 'text-white hover:text-accent hover:bg-white/10 focus:ring-white/20'
                      : 'text-muted dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:ring-gray-200 dark:focus:ring-gray-700',
                  ]}
                  aria-label={ariaLabel}
                  href={href}
                >
                  {icon && <Icon name={icon} class="w-5 h-5" />}
                  <Fragment set:html={text} />
                </a>
              </li>
            ))}
          </ul>
        ) : (
          ''
        )
      }

      <div class:list={['text-xs leading-5', theme === 'dark' ? 'text-white/65' : 'dark:text-muted']}>
        <Fragment set:html={footNote} />
      </div>
    </div>
  </div>
</footer>
