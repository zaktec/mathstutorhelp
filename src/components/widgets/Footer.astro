---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  description?: string;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], description = '', footNote = '', theme = 'light' } = Astro.props;
---

<footer
  class:list={[
    { dark: theme === 'dark' },
    'relative border-t border-gray-200 dark:border-[#021E42] not-prose',
    { 'bg-[#00387D] text-white': theme === 'dark' },
  ]}
>
  <div
    class:list={[
      'absolute inset-0 pointer-events-none',
      theme === 'dark' ? 'bg-[#00387D]' : 'dark:bg-dark',
    ]}
    aria-hidden="true"
  ></div>
  <div
    class:list={[
      'relative max-w-7xl mx-auto px-4 sm:px-6 intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade',
      theme === 'dark' ? 'text-white' : 'dark:text-slate-300',
    ]}
  >
    <div class="grid grid-cols-12 gap-4 gap-y-8 sm:gap-8 py-8 md:py-12">
      <div class="col-span-12 lg:col-span-3">
        <div class="mb-2">
          <a class="inline-block font-bold text-2xl text-white" href={getHomePermalink()}>{SITE?.name}</a>
        </div>
        {description && <p class="max-w-sm text-sm leading-6 text-white/85" set:html={description} />}
      </div>
      {
        links.map(({ title, links }) => (
          <div class="col-span-6 md:col-span-3 lg:col-span-2">
            <div class:list={['font-semibold mb-3', theme === 'dark' ? 'text-white' : 'dark:text-gray-300']}>{title}</div>
            {links && Array.isArray(links) && links.length > 0 && (
              <ul class="text-sm leading-6">
                {links.map(({ text, href, ariaLabel }) => (
                  <li class="mb-1.5">
                    <a
                      class:list={[
                        'hover:underline transition duration-150 ease-in-out',
                        theme === 'dark'
                          ? 'text-white/85 hover:text-[#F7B200]'
                          : 'text-muted hover:text-gray-700 dark:text-gray-400',
                      ]}
                      href={href}
                      aria-label={ariaLabel}
                    >
                      <Fragment set:html={text} />
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </div>
    <div class="border-t border-white/15 py-5">
      <div class:list={['text-sm flex gap-1 flex-wrap', theme === 'dark' ? 'text-white/85' : 'text-muted']}>
        {
          secondaryLinks.map(({ text, href }, index) => (
            <>
              {index !== 0 ? ' · ' : ''}
              <a
                class:list={[
                  'hover:underline transition duration-150 ease-in-out',
                  theme === 'dark'
                    ? 'text-white/85 hover:text-[#F7B200]'
                    : 'text-muted hover:text-gray-700 dark:text-gray-400',
                ]}
                href={href}
                set:html={text}
              />
            </>
          ))
        }
      </div>
    </div>
    <div class="md:flex md:items-center md:justify-between py-5">
      {
        socialLinks?.length ? (
          <ul class="flex mb-4 md:order-1 -ml-2 md:ml-4 md:mb-0 rtl:ml-0 rtl:-mr-2 rtl:md:ml-0 rtl:md:mr-4">
            {socialLinks.map(({ ariaLabel, href, text, icon }) => (
              <li>
                <a
                  class:list={[
                    'focus:outline-none focus:ring-4 rounded-lg text-sm p-2.5 inline-flex items-center',
                    theme === 'dark'
                      ? 'text-white hover:text-[#F7B200] hover:bg-white/10 focus:ring-white/20'
                      : 'text-muted dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:ring-gray-200 dark:focus:ring-gray-700',
                  ]}
                  aria-label={ariaLabel}
                  href={href}
                >
                  {icon && <Icon name={icon} class="w-5 h-5" />}
                  <Fragment set:html={text} />
                </a>
              </li>
            ))}
          </ul>
        ) : (
          ''
        )
      }

      <div class:list={['text-sm mr-4', theme === 'dark' ? 'text-white/85' : 'dark:text-muted']}>
        <Fragment set:html={footNote} />
      </div>
    </div>
  </div>
</footer>
