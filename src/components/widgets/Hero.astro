---
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';
import { SITE } from 'astrowind:config';
import { trimSlash } from '~/utils/permalinks';

import type { Hero as Props } from '~/types';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,

  content = await Astro.slots.render('content'),
  actions = await Astro.slots.render('actions'),
  image = await Astro.slots.render('image'),

  id,
  bg = await Astro.slots.render('bg'),
} = Astro.props;

const basePath = `/${trimSlash(SITE.base || '')}`;
const pathname = new URL(Astro.url).pathname;
const normalizedPath = `/${trimSlash(pathname)}`;
const isHomepage = normalizedPath === '/' || normalizedPath === basePath;
---

<section class="relative lg:-mt-[76px] not-prose" {...id ? { id } : {}}>
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <slot name="bg">
      {bg ? <Fragment set:html={bg} /> : null}
    </slot>
  </div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <div class="pt-0 lg:pt-[76px] pointer-events-none"></div>
    <div class:list={[isHomepage ? 'py-12 md:py-20' : 'py-8 md:py-12']}>
      <div class:list={['text-center max-w-5xl mx-auto', isHomepage ? 'pb-10 md:pb-16' : 'pb-6 md:pb-8']}>
        {
          tagline && (
            <p
              class="text-base text-secondary dark:text-teal-200 font-bold tracking-wide uppercase intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
              set:html={tagline}
            />
          )
        }
        {
          title && (
            <h1
              class:list={[
                'font-bold leading-tighter tracking-tighter mb-4 font-heading dark:text-gray-200 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade',
                isHomepage ? 'text-4xl sm:text-5xl md:text-6xl' : 'text-4xl md:text-5xl',
              ]}
              set:html={title}
            />
          )
        }
        <div class="max-w-3xl mx-auto">
          {
            subtitle && (
              <p
                class="text-xl text-muted mb-6 dark:text-slate-300 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
                set:html={subtitle}
              />
            )
          }
          {
            actions && (
              <div class="max-w-xs sm:max-w-md m-auto flex flex-nowrap flex-col sm:flex-row sm:justify-center gap-4 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
                {Array.isArray(actions) ? (
                  actions.map((action) => (
                    <div class="flex w-full sm:w-auto">
                      <Button {...(action || {})} class="w-full sm:mb-0" />
                    </div>
                  ))
                ) : (
                  <Fragment set:html={actions} />
                )}
              </div>
            )
          }
        </div>
        {content && <Fragment set:html={content} />}
      </div>
      <div
        class="intersect-once intersect-no-queue intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
      >
        {
          image && (
            <div class:list={['relative m-auto', isHomepage ? 'max-w-5xl' : 'max-w-4xl']}>
              {typeof image === 'string' ? (
                <Fragment set:html={image} />
              ) : (
                <Image
                  class:list={['mx-auto w-full', isHomepage ? 'rounded-md' : 'rounded-lg max-h-[360px] object-cover']}
                  widths={[400, 768, 1024, 2040]}
                  sizes="(max-width: 767px) 400px, (max-width: 1023px) 768px, (max-width: 2039px) 1024px, 2040px"
                  loading="eager"
                  fetchpriority="high"
                  width={1024}
                  height={576}
                  format="webp"
                  {...image}
                />
              )}
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
