---
import Image from '~/components/common/Image.astro';

interface GalleryImage {
  src: string;
  alt: string;
  title?: string;
}

interface Props {
  images: GalleryImage[];
}

const { images = [] } = Astro.props;
---

<section class="bg-white py-10 dark:bg-slate-900 md:py-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        images.map((image) => (
          <figure class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-slate-800">
            <Image
              class="aspect-[4/3] w-full object-cover"
              src={image.src}
              alt={image.alt}
              width={640}
              height={480}
              widths={[400, 640, 960]}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
              layout="responsive"
              format="webp"
            />
            {image.title && (
              <figcaption class="p-4 text-sm font-semibold text-gray-900 dark:text-white">{image.title}</figcaption>
            )}
          </figure>
        ))
      }
    </div>
  </div>
</section>
